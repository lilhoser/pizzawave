                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Path Width="28" Height="28"
                              Stretch="Uniform"
                              VerticalAlignment="Center"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M4.5,1.8 L9.5,1.8 L9.5,5.2 L4.5,5.2 Z M4.5,5.8 L9.5,5.8 L9.5,9.2 L4.5,9.2 Z M4.5,9.8 L9.5,9.8 L9.5,13.2 L4.5,13.2 Z M5.7,2.6 L8.3,2.6 L8.3,4.4 L5.7,4.4 Z M5.7,6.6 L8.3,6.6 L8.3,8.4 L5.7,8.4 Z M5.7,10.6 L8.3,10.6 L8.3,12.4 L5.7,12.4 Z"/>
                        <TextBlock Text="Traffic" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="menu-btn menu-main-btn"
                        Cursor="Hand"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding IsOtherMenuVisible}"
                        Background="{Binding IsOtherSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#8a63d2,#4a4a4a'}"
                        Foreground="{Binding IsOtherSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnSectionOtherClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Path Width="28" Height="28"
                              Stretch="Uniform"
                              VerticalAlignment="Center"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M7,2 C9.5,2 11.4,3.8 11.4,6.1 C11.4,7.7 10.4,8.8 9.2,9.5 C8.6,9.9 8.4,10.2 8.4,10.8 L6.8,10.8 C6.8,9.9 7.1,9.2 7.8,8.7 C8.8,8 9.6,7.4 9.6,6.2 C9.6,5 8.5,4.2 7.1,4.2 C5.8,4.2 4.9,5 4.6,6.1 L3,5.6 C3.5,3.5 5.1,2 7,2 Z M6.8,11.8 L8.4,11.8 L8.4,13.3 L6.8,13.3 Z"/>
                        <TextBlock Text="Other" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Separator Margin="0,2,0,2"/>

                <Button Classes="menu-btn menu-main-btn"
                        Cursor="Hand"
                        HorizontalAlignment="Stretch"
                        Background="{Binding IsSettingsSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#ff9900,#4a4a4a'}"
                        Foreground="{Binding IsSettingsSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnSectionSettingsClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Path Width="28" Height="28"
                              Stretch="Uniform"
                              VerticalAlignment="Center"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M6.9,2 L7.7,2 L8,3.1 C8.4,3.2 8.8,3.3 9.1,3.5 L10.1,2.9 L10.7,3.5 L10.1,4.5 C10.3,4.8 10.4,5.2 10.5,5.6 L11.6,5.9 L11.6,6.7 L10.5,7 C10.4,7.4 10.3,7.8 10.1,8.1 L10.7,9.1 L10.1,9.7 L9.1,9.1 C8.8,9.3 8.4,9.4 8,9.5 L7.7,10.6 L6.9,10.6 L6.6,9.5 C6.2,9.4 5.8,9.3 5.5,9.1 L4.5,9.7 L3.9,9.1 L4.5,8.1 C4.3,7.8 4.2,7.4 4.1,7 L3,6.7 L3,5.9 L4.1,5.6 C4.2,5.2 4.3,4.8 4.5,4.5 L3.9,3.5 L4.5,2.9 L5.5,3.5 C5.8,3.3 6.2,3.2 6.6,3.1 Z M7.3,4.7 C6.4,4.7 5.7,5.4 5.7,6.3 C5.7,7.2 6.4,7.9 7.3,7.9 C8.2,7.9 8.9,7.2 8.9,6.3 C8.9,5.4 8.2,4.7 7.3,4.7 Z"/>
                        <TextBlock Text="Settings" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="menu-btn menu-main-btn"
                        Cursor="Hand"
                        HorizontalAlignment="Stretch"
                        Background="{Binding IsTroubleshootSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#ff5555,#4a4a4a'}"
                        Foreground="{Binding IsTroubleshootSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnSectionTroubleshootClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Path Width="28" Height="28"
                              Stretch="Uniform"
                              VerticalAlignment="Center"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M7,2 L12,11 L2,11 Z M6.6,5 L7.4,5 L7.4,8 L6.6,8 Z M6.6,8.8 L7.4,8.8 L7.4,9.6 L6.6,9.6 Z"/>
                        <TextBlock Text="{Binding TroubleshootMenuText}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Separator Margin="0,2,0,2"/>

                <Button Classes="menu-btn"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        Width="48"
                        MinWidth="48"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Foreground="White"
                        Padding="0"
                        ToolTip.Tip="{Binding BellToolTipText}"
                        Click="OnBellMenuClicked">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Width="36" Height="36"
                              Fill="Transparent"
                              Stroke="{Binding BellColor}"
                              StrokeThickness="2.2"
                              Stretch="Uniform"
                              Data="M7,2 C5.2,2 3.8,3.4 3.8,5.2 L3.8,8.1 L2.7,9.4 L2.7,10 L11.3,10 L11.3,9.4 L10.2,8.1 L10.2,5.2 C10.2,3.4 8.8,2 7,2 Z M6.1,10.8 C6.1,11.3 6.5,11.7 7,11.7 C7.5,11.7 7.9,11.3 7.9,10.8 Z"/>
                    </Grid>
                </Button>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
        <!-- Main Content Area -->
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Category split view: insights tiles + raw calls -->
            <Grid Grid.Row="1"
                  Grid.Column="0"
                  IsVisible="{Binding IsCallsSectionVisible}"
                  Margin="10"
                  ColumnDefinitions="3*,6,5*">
                <Border Grid.Column="0"
                        Background="#1f2f3d"
                        BorderBrush="#36566f"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8">
                    <Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding InsightsCategorySections}"
                                          ItemTemplate="{StaticResource InsightCategoryTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                        <Border IsVisible="{Binding IsCategoryInsightsEmpty}"
                                Background="#253645"
                                BorderBrush="#36566f"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <StackPanel Spacing="12">
                                <TextBlock Text="No insights summaries available for calls in this category and time range"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="#cfe7ff"
                                           TextWrapping="Wrap"/>
                                <Button Classes="menu-btn"
                                        Content="Generate summaries now"
                                        HorizontalAlignment="Left"
                                        IsVisible="{Binding IsGenerateNowVisible}"
                                        IsEnabled="{Binding CanGenerateNow}"
                                        Click="OnGenerateSummariesNowClicked"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1"
                              Width="6"
                              Background="#36566f"
                              ResizeDirection="Columns"
                              ShowsPreview="True"/>

                <Border Grid.Column="2"
                        Padding="0">
                    <Grid>
                        <DataGrid x:Name="CategoryCallsDataGrid"
                                  ItemsSource="{Binding CategoryGroupedCalls}"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="None"
                                  GridLinesVisibility="None"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  CanUserResizeColumns="False"
                                  CanUserSortColumns="False"
                                  SelectionMode="Single"
                                  RowHeaderWidth="24"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  RowBackground="Transparent"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="local:CallGroupItem">
                                            <ContentControl Content="{Binding}"
                                                            ContentTemplate="{StaticResource CallGroupTemplateSelector}"
                                                            HorizontalAlignment="Stretch"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                            <DataGrid.Styles>
                                <Style Selector="DataGridCell">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                                <Style Selector="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </DataGrid.Styles>
                        </DataGrid>
                        <Border IsVisible="{Binding IsCategoryRawCallsEmpty}"
                                Background="#1f2f3d"
                                BorderBrush="#36566f"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <TextBlock Text="No raw calls available for this category"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#dddddd"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Dashboard -->
            <Grid Grid.Row="1"
                  Grid.Column="0"
                  IsVisible="{Binding IsInsightsSectionVisible}">
                <Grid>
                    <Grid Margin="10"
                          ColumnDefinitions="*,10,*">
                        <Border Grid.Column="0"
                                Background="#1f2f3d"
                                BorderBrush="#36566f"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8">
                            <Grid>
                                <Grid>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel Spacing="10">
                                            <Border Background="#223748" BorderBrush="#36566f" BorderThickness="1" CornerRadius="6" Padding="8">
                                                <StackPanel Spacing="8">
                                                    <ItemsControl ItemsSource="{Binding DashboardSimpleStats}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Horizontal" ItemWidth="190"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="local:DashboardSimpleStat">
                                                                <Border Background="#1e2f3d" BorderBrush="#36566f" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,8,8">
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding Label}" Foreground="#9fc1dd"/>
                                                                        <TextBlock Text="{Binding Value}" Foreground="#d7ecff" FontSize="22" FontWeight="Bold"/>
                                                                        <TextBlock Text="{Binding SubValue}" Foreground="#9fc1dd" FontSize="11" TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                            <TextBlock Text="Volume Patterns"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="#9fc1dd"/>
                                            <Border Background="#223748"
                                                    BorderBrush="#36566f"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="8">
                                                <StackPanel Spacing="8">
                                                    <ItemsControl ItemsSource="{Binding DashboardCategoryVolumeCharts}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid RowDefinitions="Auto,150,Auto,Auto" ColumnDefinitions="56,*">
                                                                    <StackPanel Grid.ColumnSpan="2" Spacing="2">
                                                                        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="#cfe7ff"/>
                                                                        <TextBlock Text="{Binding YAxisLabel}" Foreground="#9fc1dd" FontSize="11"/>
                                                                    </StackPanel>
                                                                    <Grid Grid.Row="1" Grid.Column="0" RowDefinitions="Auto,*,Auto" Margin="0,14,6,18">
                                                                        <TextBlock Text="{Binding MaxLabel}" Foreground="#9fc1dd" FontSize="11" HorizontalAlignment="Right"/>
                                                                        <TextBlock Grid.Row="1" Text="{Binding YTick3Label}" Foreground="#9fc1dd" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,24,0,0"/>
                                                                        <TextBlock Grid.Row="1" Text="{Binding YTick2Label}" Foreground="#9fc1dd" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                                        <TextBlock Grid.Row="1" Text="{Binding YTick1Label}" Foreground="#9fc1dd" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,24"/>
                                                                        <TextBlock Grid.Row="2" Text="{Binding MinLabel}" Foreground="#9fc1dd" FontSize="11" HorizontalAlignment="Right"/>
                                                                    </Grid>
                                                                    <Canvas Grid.Row="1" Grid.Column="1" Width="640" Height="140" ClipToBounds="True" Background="#1e2f3d">
                                                                        <Line StartPoint="42,12" EndPoint="42,118" Stroke="#666" StrokeThickness="1"/>
                                                                        <Line StartPoint="42,118" EndPoint="620,118" Stroke="#666" StrokeThickness="1"/>
                                                                        <Line StartPoint="42,91.5" EndPoint="620,91.5" Stroke="#2f2f2f" StrokeThickness="1"/>
                                                                        <Line StartPoint="42,65" EndPoint="620,65" Stroke="#333" StrokeThickness="1"/>
                                                                        <Line StartPoint="42,38.5" EndPoint="620,38.5" Stroke="#2f2f2f" StrokeThickness="1"/>
                                                                        <Polyline Points="{Binding Series1Points}" Stroke="#62c6ff" StrokeThickness="2"/>
                                                                        <Polyline Points="{Binding Series2Points}" Stroke="#ffcf5a" StrokeThickness="2"/>
                                                                        <Polyline Points="{Binding Series3Points}" Stroke="#7ee081" StrokeThickness="2"/>
                                                                        <Polyline Points="{Binding Series4Points}" Stroke="#ff8c69" StrokeThickness="2"/>
                                                                        <Polyline Points="{Binding Series5Points}" Stroke="#c792ea" StrokeThickness="2"/>
                                                                        <Polyline Points="{Binding Series6Points}" Stroke="#b8cde1" StrokeThickness="2"/>
                                                                    </Canvas>
                                                                    <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,*,*,*,*,*,*" Margin="42,0,20,0">
                                                                        <TextBlock Grid.Column="0" Text="{Binding XTick0Label}" FontSize="11" Foreground="#9fc1dd" HorizontalAlignment="Left"/>
                                                                        <TextBlock Grid.Column="1" Text="{Binding XTick1Label}" FontSize="11" Foreground="#9fc1dd" HorizontalAlignment="Center"/>
                                                                        <TextBlock Grid.Column="2" Text="{Binding XTick2Label}" FontSize="11" Foreground="#9fc1dd" HorizontalAlignment="Center"/>
                                                                        <TextBlock Grid.Column="3" Text="{Binding XTick3Label}" FontSize="11" Foreground="#9fc1dd" HorizontalAlignment="Center"/>
                                                                        <TextBlock Grid.Column="4" Text="{Binding XTick4Label}" FontSize="11" Foreground="#9fc1dd" HorizontalAlignment="Center"/>
                                                                        <TextBlock Grid.Column="5" Text="{Binding XTick5Label}" FontSize="11" Foreground="#9fc1dd" HorizontalAlignment="Center"/>
                                                                        <TextBlock Grid.Column="6" Text="{Binding EndLabel}" FontSize="11" Foreground="#9fc1dd" HorizontalAlignment="Right"/>
                                                                    </Grid>
                                                                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="12" Margin="0,6,0,0" IsVisible="{Binding HasLegend}">
                                                                        <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding Series1Label, Converter={StaticResource StringHasTextConverter}}">
                                                                            <Border Width="16" Height="3" Background="#62c6ff" VerticalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding Series1Label}" FontSize="11" Foreground="#d7ecff"/>
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding Series2Label, Converter={StaticResource StringHasTextConverter}}">
                                                                            <Border Width="16" Height="3" Background="#ffcf5a" VerticalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding Series2Label}" FontSize="11" Foreground="#d7ecff"/>
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding Series3Label, Converter={StaticResource StringHasTextConverter}}">
                                                                            <Border Width="16" Height="3" Background="#7ee081" VerticalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding Series3Label}" FontSize="11" Foreground="#d7ecff"/>
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding Series4Label, Converter={StaticResource StringHasTextConverter}}">
                                                                            <Border Width="16" Height="3" Background="#ff8c69" VerticalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding Series4Label}" FontSize="11" Foreground="#d7ecff"/>
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding Series5Label, Converter={StaticResource StringHasTextConverter}}">
                                                                            <Border Width="16" Height="3" Background="#c792ea" VerticalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding Series5Label}" FontSize="11" Foreground="#d7ecff"/>
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding Series6Label, Converter={StaticResource StringHasTextConverter}}">
                                                                            <Border Width="16" Height="3" Background="#b8cde1" VerticalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding Series6Label}" FontSize="11" Foreground="#d7ecff"/>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#223748"
                                                    BorderBrush="#36566f"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="8">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Top Talkgroups by Call Volume"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Foreground="#cfe7ff"/>
                                                    <Grid ColumnDefinitions="2.2*,70,70,92,150"
                                                          ColumnSpacing="10"
                                                          Margin="0,0,0,2">
                                                        <TextBlock Text="Talkgroup" Foreground="#9fc1dd" FontSize="11"/>
                                                        <TextBlock Grid.Column="1" Text="Calls" Foreground="#9fc1dd" FontSize="11" HorizontalAlignment="Right"/>
                                                        <TextBlock Grid.Column="2" Text="Share" Foreground="#9fc1dd" FontSize="11" HorizontalAlignment="Right"/>
                                                        <TextBlock Grid.Column="3" Text="Last heard" Foreground="#9fc1dd" FontSize="11"/>
                                                        <TextBlock Grid.Column="4" Text="Trend" Foreground="#9fc1dd" FontSize="11"/>
                                                    </Grid>
                                                    <ItemsControl ItemsSource="{Binding DashboardTalkgroupTrendRows}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="local:DashboardTalkgroupTrendRow">
                                                                <Grid ColumnDefinitions="2.2*,70,70,92,150"
                                                                      ColumnSpacing="10"
                                                                      Margin="0,2,0,2">
                                                                    <Grid RowDefinitions="Auto,Auto">
                                                                        <TextBlock Text="{Binding Talkgroup}"
                                                                                   Foreground="#d7ecff"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                        <ProgressBar Grid.Row="1"
                                                                                     Minimum="0"
                                                                                     Maximum="1"
                                                                                     Value="{Binding CountRatio}"
                                                                                     Height="3"
                                                                                     Margin="0,3,0,0"/>
                                                                    </Grid>
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding TotalCalls}"
                                                                               Foreground="#d7ecff"
                                                                               HorizontalAlignment="Right"/>
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{Binding ShareText}"
                                                                               Foreground="#9fc1dd"
                                                                               HorizontalAlignment="Right"/>
                                                                    <TextBlock Grid.Column="3"
                                                                               Text="{Binding LastHeardText}"
                                                                               Foreground="#9fc1dd"
                                                                               FontSize="12"/>
                                                                    <Grid Grid.Column="4" RowDefinitions="Auto,Auto">
                                                                        <ItemsControl ItemsSource="{Binding Bars}">
                                                                            <ItemsControl.ItemsPanel>
                                                                                <ItemsPanelTemplate>
                                                                                    <StackPanel Orientation="Horizontal" Spacing="2"/>
                                                                                </ItemsPanelTemplate>
                                                                            </ItemsControl.ItemsPanel>
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate x:DataType="local:DashboardMiniBar">
                                                                                    <Border Width="10" Height="16" Background="#62c6ff" Opacity="{Binding DisplayOpacity}"/>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*" Margin="0,2,0,0">
                                                                            <TextBlock Text="{Binding TrendStartLabel}"
                                                                                       Foreground="#7898ad"
                                                                                       FontSize="9"/>
                                                                            <TextBlock Grid.Column="1"
                                                                                       Text="{Binding TrendBucketLabel}"
                                                                                       Foreground="#7898ad"
                                                                                       FontSize="9"
                                                                                       HorizontalAlignment="Center"/>
                                                                            <TextBlock Grid.Column="2"
                                                                                       Text="{Binding TrendEndLabel}"
                                                                                       Foreground="#7898ad"
                                                                                       FontSize="9"
                                                                                       HorizontalAlignment="Right"/>
                                                                        </Grid>
                                                                    </Grid>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                            <TextBlock Text="Transcription Quality"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="#9fc1dd"/>
                                            <Border Background="#223748"
                                                    BorderBrush="#36566f"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="8">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBlock Text="Quality Problems by Hour"
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#cfe7ff"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding DashboardQualityProblemTotalText}"
                                                                   Foreground="#9fc1dd"
                                                                   FontSize="12"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <ItemsControl ItemsSource="{Binding DashboardQualityHourRows}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal" Spacing="4"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="local:DashboardQualityHourStackRow">
                                                                <Grid RowDefinitions="110,Auto,Auto" Width="24">
                                                                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Spacing="0">
                                                                        <Border Width="18" Height="{Binding EmptyHeight}" Background="#ff5a70"/>
                                                                        <Border Width="18" Height="{Binding FailureHeight}" Background="#ff9f43"/>
                                                                        <Border Width="18" Height="{Binding InaudibleHeight}" Background="#62c6ff"/>
                                                                        <Border Width="18" Height="{Binding ShortHeight}" Background="#ffcf5a"/>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Row="1" Text="{Binding TotalText}" Foreground="#d7ecff" FontSize="10" HorizontalAlignment="Center"/>
                                                                    <TextBlock Grid.Row="2" Text="{Binding HourTickLabel}" Foreground="#9fc1dd" FontSize="10" HorizontalAlignment="Center"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <Border Width="14" Height="3" Background="#ff5a70" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Empty" Foreground="#d7ecff" FontSize="11"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <Border Width="14" Height="3" Background="#ff9f43" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Failure" Foreground="#d7ecff" FontSize="11"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <Border Width="14" Height="3" Background="#62c6ff" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Inaudible" Foreground="#d7ecff" FontSize="11"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <Border Width="14" Height="3" Background="#ffcf5a" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Short" Foreground="#d7ecff" FontSize="11"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#223748" BorderBrush="#36566f" BorderThickness="1" CornerRadius="6" Padding="8">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Inaudible by System" FontSize="16" FontWeight="SemiBold" Foreground="#cfe7ff"/>
                                                    <ItemsControl ItemsSource="{Binding DashboardQualitySystemRows}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="local:DashboardBarStatRow">
                                                                <Grid ColumnDefinitions="220,*,64" ColumnSpacing="8" Margin="0,1,0,1">
                                                                    <TextBlock Text="{Binding Label}" Foreground="#d7ecff" TextTrimming="CharacterEllipsis"/>
                                                                    <ProgressBar Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding Ratio}" Height="12"/>
                                                                    <TextBlock Grid.Column="2" Text="{Binding ValueText}" Foreground="#9fc1dd" HorizontalAlignment="Right"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#223748" BorderBrush="#36566f" BorderThickness="1" CornerRadius="6" Padding="8">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Problem Talkgroups" FontSize="16" FontWeight="SemiBold" Foreground="#cfe7ff"/>
                                                    <ItemsControl ItemsSource="{Binding DashboardQualityTalkgroupRows}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="local:DashboardBarStatRow">
                                                                <Grid ColumnDefinitions="220,*,64" ColumnSpacing="8" Margin="0,1,0,1">
                                                                    <TextBlock Text="{Binding Label}" Foreground="#d7ecff" TextTrimming="CharacterEllipsis"/>
                                                                    <ProgressBar Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding Ratio}" Height="12"/>
                                                                    <TextBlock Grid.Column="2" Text="{Binding ValueText}" Foreground="#9fc1dd" HorizontalAlignment="Right"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                            <TextBlock Text="Distribution"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="#9fc1dd"/>
                                            <Border Background="#223748" BorderBrush="#36566f" BorderThickness="1" CornerRadius="6" Padding="8">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Category Share" FontSize="16" FontWeight="SemiBold" Foreground="#cfe7ff"/>
                                                    <ItemsControl ItemsSource="{Binding DashboardCategoryShareRows}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="local:DashboardBarStatRow">
                                                                <Grid ColumnDefinitions="130,*,68" ColumnSpacing="8" Margin="0,1,0,1">
                                                                    <TextBlock Text="{Binding Label}" Foreground="#d7ecff"/>
                                                                    <ProgressBar Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding Ratio}" Height="12"/>
                                                                    <TextBlock Grid.Column="2" Text="{Binding ValueText}" Foreground="#9fc1dd" HorizontalAlignment="Right"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                            <TextBlock Text="Exploration"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="#9fc1dd"/>
                                            <Border Background="#223748" BorderBrush="#36566f" BorderThickness="1" CornerRadius="6" Padding="8">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Alert-Only Keywords" FontSize="16" FontWeight="SemiBold" Foreground="#cfe7ff"/>
                                                    <ItemsControl ItemsSource="{Binding DashboardAlertKeywordRows}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="local:DashboardBarStatRow">
                                                                <Grid ColumnDefinitions="160,*,56" ColumnSpacing="8" Margin="0,1,0,1">
                                                                    <TextBlock Text="{Binding Label}" Foreground="#d7ecff"/>
                                                                    <ProgressBar Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding Ratio}" Height="12"/>
                                                                    <TextBlock Grid.Column="2" Text="{Binding ValueText}" Foreground="#9fc1dd" HorizontalAlignment="Right"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                    <Border IsVisible="{Binding IsHighlightsEmpty}"
                                            Background="#253645"
                                            BorderBrush="#36566f"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="14"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top">
                                        <StackPanel Spacing="12">
                                            <TextBlock Text="No highlights available for the given time range"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="#cfe7ff"
                                                       TextWrapping="Wrap"/>
                                            <Button Classes="menu-btn"
                                                    Content="Generate highlights now"
                                                    HorizontalAlignment="Left"
                                                    IsVisible="{Binding IsGenerateNowVisible}"
                                                    IsEnabled="{Binding CanGenerateNow}"
                                                    Click="OnGenerateHighlightsNowClicked"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Column="1"
                                      Width="10"
                                      Background="#36566f"
                                      ResizeDirection="Columns"
                                      ShowsPreview="True"/>

                        <Grid Grid.Column="2"
                              RowDefinitions="*,10,*">
                        <Border Grid.Row="0"
                                Background="#252525"
                                BorderBrush="#3c3c3c"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8">
                            <Grid RowDefinitions="Auto,*">
                                <TextBlock Text="Alerts"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#cfe7ff"
                                           Margin="0,0,0,8"/>
                                <Grid Grid.Row="1">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding AlertHistory}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"
                                                               ItemWidth="245"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="local:AlertMatchRecord">
                                                    <Border Background="#1e2f3d"
                                                            BorderBrush="#36566f"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Margin="0,0,8,8"
                                                            Padding="8">
                                                        <Grid ColumnDefinitions="Auto,*"
                                                              RowDefinitions="Auto,Auto"
                                                              ColumnSpacing="8"
                                                              RowSpacing="6">
                                                            <Button Grid.Column="0"
                                                                    Grid.RowSpan="2"
                                                                    Classes="menu-btn"
                                                                    Height="40"
                                                                    MinWidth="74"
                                                                    Padding="8,4"
                                                                    Click="OnAlertHistoryPlayClicked">
                                                                <Grid Width="22" Height="22">
                                                                    <Path Data="M8 5.14V19.14L19 12.14L8 5.14Z"
                                                                          Fill="#4CAF50"
                                                                          IsVisible="{Binding IsAudioPlaying, Converter={StaticResource InvertedBoolConverter}}"/>
                                                                    <Path Data="M6 6H18V18H6V6Z"
                                                                          Fill="#f44336"
                                                                          IsVisible="{Binding IsAudioPlaying}"/>
                                                                </Grid>
                                                            </Button>
                                                            <TextBlock Grid.Column="1"
                                                                       Grid.Row="0"
                                                                       TextWrapping="Wrap"
                                                                       VerticalAlignment="Top">
                                                                <Run Text="{Binding HighlightPrefix}"/>
                                                                <Run Text="{Binding HighlightMatch}"
                                                                     Foreground="#101010"
                                                                     Background="#ffd24d"
                                                                     FontWeight="Bold"/>
                                                                <Run Text="{Binding HighlightSuffix}"/>
                                                            </TextBlock>
                                                            <WrapPanel Grid.Column="1"
                                                                       Grid.Row="1"
                                                                       Orientation="Horizontal">
                                                                <TextBlock Text="{Binding AlertType}"
                                                                           Foreground="#ffd27a"
                                                                           Margin="0,0,10,0"/>
                                                                <TextBlock Text="{Binding DurationSec, StringFormat='{}{0}s'}"
                                                                           Foreground="#8ec7ff"
                                                                           Margin="0,0,10,0"/>
                                                                <TextBlock Text="{Binding DisplayTimestamp}"
                                                                           Foreground="#9fc1dd"/>
                                                            </WrapPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <Border IsVisible="{Binding IsAlertsEmpty}"
                                            Background="#223748"
                                            BorderBrush="#36566f"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="14"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top">
                                        <StackPanel Spacing="12">
                                            <TextBlock Text="No alerts available for the given time range"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="#cfe7ff"
                                                       TextWrapping="Wrap"/>
                                            <Button Classes="menu-btn"
                                                    Content="Go to alert configuration"
                                                    HorizontalAlignment="Left"
                                                    Click="OnGoToAlertConfigurationClicked"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Row="1"
                                      Height="10"
                                      Background="#36566f"
                                      ResizeDirection="Rows"
                                      ShowsPreview="True"/>

                        <Border Grid.Row="2"
                                Background="#1f2f3d"
                                BorderBrush="#36566f"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8">
                            <Grid RowDefinitions="Auto,*">
                                <TextBlock Text="Incident Explorer"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#cfe7ff"
                                           Margin="0,0,0,8"/>
                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <TextBlock Text="Active Incidents"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="#cfe7ff"/>
                                            <Button Grid.Column="1"
                                                    Classes="menu-btn"
                                                    Content="{Binding DashboardIncidentExpandAllText}"
                                                    Padding="8,3"
                                                    MinHeight="28"
                                                    IsVisible="{Binding HasDashboardIncidentDetails}"
                                                    Click="OnDashboardIncidentExpandAllClicked"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding DashboardIncidentBuckets}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="local:DashboardIncidentBucket">
                                                    <Border Background="#1e2f3d" BorderBrush="#36566f" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                                                        <StackPanel Spacing="4">
                                                            <Grid ColumnDefinitions="*,Auto">
                                                                <TextBlock Text="{Binding BucketName}" Foreground="#d7ecff" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding UpdateCountText}" Foreground="#9fc1dd"/>
                                                            </Grid>
                                                            <Grid ColumnDefinitions="*,Auto">
                                                                <TextBlock Text="{Binding TimeRangeText}" Foreground="#9fc1dd" FontSize="11"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding SourceText}" Foreground="#ffd27a" FontSize="11"/>
                                                            </Grid>
                                                            <TextBlock Text="{Binding PreviewText}" Foreground="#d7ecff" TextWrapping="Wrap"/>
                                                            <Button Classes="menu-btn"
                                                                    Content="{Binding ExpandLabel}"
                                                                    Padding="8,3"
                                                                    MinHeight="28"
                                                                    HorizontalAlignment="Left"
                                                                    IsVisible="{Binding HasEventDetails}"
                                                                    Click="OnDashboardIncidentToggleClicked"/>
                                                            <Border Background="#192936"
                                                                    BorderBrush="#36566f"
                                                                    BorderThickness="1"
                                                                    CornerRadius="4"
                                                                    Padding="6"
                                                                    Margin="0,4,0,0"
                                                                    IsVisible="{Binding IsDetailVisible}">
                                                                <StackPanel Spacing="5">
                                                                    <TextBlock Text="Related calls"
                                                                               Foreground="#9fc1dd"
                                                                               FontSize="11"
                                                                               FontWeight="SemiBold"/>
                                                                    <ItemsControl ItemsSource="{Binding EventDetails}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate x:DataType="local:DashboardIncidentDetail">
                                                                                <Border BorderBrush="#2b465a"
                                                                                        BorderThickness="0,1,0,0"
                                                                                        Padding="0,5,0,0"
                                                                                        Margin="0,0,0,2">
                                                                                    <StackPanel Spacing="2">
                                                                                        <TextBlock Text="{Binding Title}"
                                                                                                   Foreground="#d7ecff"
                                                                                                   FontWeight="SemiBold"
                                                                                                   TextWrapping="Wrap"/>
                                                                                        <TextBlock Text="{Binding MetaText}"
                                                                                                   Foreground="#9fc1dd"
                                                                                                   FontSize="11"
                                                                                                   TextWrapping="Wrap"/>
                                                                                        <TextBlock Text="{Binding Detail}"
                                                                                                   Foreground="#c5def3"
                                                                                                   TextWrapping="Wrap"/>
                                                                                        <StackPanel Orientation="Horizontal"
                                                                                                    Spacing="6"
                                                                                                    IsVisible="{Binding HasSourceCall}">
                                                                                            <Button Content="Transcript"
                                                                                                    Classes="menu-btn"
                                                                                                    Padding="8,3"
                                                                                                    MinHeight="28"
                                                                                                    Foreground="#7dd3fc"
                                                                                                    Click="OnDashboardIncidentUpdateTranscriptClicked"/>
                                                                                            <Button Content="Audio"
                                                                                                    Classes="menu-btn"
                                                                                                    Padding="8,3"
                                                                                                    MinHeight="28"
                                                                                                    Foreground="#7dd3fc"
                                                                                                    Click="OnDashboardIncidentUpdateAudioClicked"/>
                                                                                        </StackPanel>
                                                                                    </StackPanel>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="No incidents detected."
                                                   IsVisible="{Binding IsDashboardIncidentBucketsEmpty}"
                                                   Foreground="#9fc1dd"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                        </Grid>
                    </Grid>

                    <!-- Loading overlay -->
                    <Border Background="#000000aa"
                            IsVisible="{Binding InsightsLoading}"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="15">
                            <ProgressBar Width="200" Height="4" Value="0" IsIndeterminate="True"/>
                            <TextBlock Text="{Binding InsightsStatusText}"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                    </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- Settings -->
            <Grid Grid.Row="1"
                  Grid.Column="0"
                  IsVisible="{Binding IsSettingsSectionVisible}">
                <Grid RowDefinitions="Auto,*" Margin="8">
                    <Grid.Styles>
                        <Style Selector="TextBox">
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        </Style>
                        <Style Selector="ComboBox">
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                        </Style>
                    </Grid.Styles>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="LoadButtonProxy" Content="Load" Classes="menu-btn" Click="OnSettingsLoadProxyClicked"/>
                        <Button x:Name="SaveButtonProxy" Content="Save" Classes="menu-btn" Click="OnSettingsSaveProxyClicked"/>
                        <Button x:Name="SaveAsButtonProxy" Content="Save As" Classes="menu-btn" Click="OnSettingsSaveAsProxyClicked"/>
                    </StackPanel>
                    <TabControl x:Name="SettingsTabControl" Grid.Row="1" Margin="0,8,0,0">
                        <TabItem Header="Trunk recorder">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Border Margin="12"
                                        Padding="14"
                                        Width="560"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Background="#232323"
                                        CornerRadius="8"
                                        BorderBrush="#3b3b3b"
                                        BorderThickness="1">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Listen Port" FontWeight="Bold"/>
                                        <TextBlock Text="TCP port where PizzaPi listens for incoming call data from Trunk Recorder."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"
                                                   TextWrapping="Wrap"/>
                                        <TextBox x:Name="SettingsListenPortTextBox"
                                                 Width="180"
                                                 HorizontalAlignment="Left"
                                                 HorizontalContentAlignment="Left"/>
                                        <Separator Margin="0,10,0,4"/>
                                        <TextBlock Text="Diagnostics" FontWeight="Bold"/>
                                        <TextBlock Text="SSH mode fetches trunk-recorder log files, caches them locally, and computes health summaries on this machine."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="Mode" FontWeight="Bold"/>
                                        <TextBlock Text="Where diagnostics are read from: local host files or SSH to Trunk Recorder."
                                                   FontSize="11" Foreground="#b0b0b0" TextWrapping="Wrap"/>
                                        <ComboBox x:Name="SettingsTrDiagnosticsModeComboBox" Width="180" HorizontalAlignment="Left">
                                            <ComboBoxItem Content="Local" />
                                            <ComboBoxItem Content="SSH" />
                                        </ComboBox>
                                        <TextBlock Text="Host" FontWeight="Bold"/>
                                        <TextBlock Text="SSH host name or IP when diagnostics mode is SSH."
                                                   FontSize="11" Foreground="#b0b0b0" TextWrapping="Wrap"/>
                                        <TextBox x:Name="SettingsTrDiagnosticsHostTextBox" Width="320" HorizontalAlignment="Left"/>
                                        <TextBlock Text="Port" FontWeight="Bold"/>
                                        <TextBlock Text="SSH port on the Trunk Recorder host (normally 22)."
                                                   FontSize="11" Foreground="#b0b0b0" TextWrapping="Wrap"/>
                                        <TextBox x:Name="SettingsTrDiagnosticsPortTextBox" Width="100" HorizontalAlignment="Left"/>
                                        <TextBlock Text="Username" FontWeight="Bold"/>
                                        <TextBlock Text="SSH user account used to read diagnostics data remotely."
                                                   FontSize="11" Foreground="#b0b0b0" TextWrapping="Wrap"/>
                                        <TextBox x:Name="SettingsTrDiagnosticsUsernameTextBox" Width="260" HorizontalAlignment="Left"/>
                                        <TextBlock Text="Authentication" FontWeight="Bold"/>
                                        <TextBlock Text="Choose password or private key authentication for SSH."
                                                   FontSize="11" Foreground="#b0b0b0" TextWrapping="Wrap"/>
                                        <ComboBox x:Name="SettingsTrDiagnosticsAuthModeComboBox" Width="180" HorizontalAlignment="Left">
                                            <ComboBoxItem Content="Password" />
                                            <ComboBoxItem Content="Private key" />
                                        </ComboBox>
                                        <TextBlock Text="Password" FontWeight="Bold"/>
                                        <TextBlock Text="SSH password (stored securely; leave blank to keep existing)."
                                                   FontSize="11" Foreground="#b0b0b0" TextWrapping="Wrap"/>
                                        <TextBox x:Name="SettingsTrDiagnosticsPasswordTextBox" Width="260" HorizontalAlignment="Left"/>
                                        <TextBlock Text="Private Key Path" FontWeight="Bold"/>
                                        <TextBlock Text="Path to SSH private key file for private-key authentication."
                                                   FontSize="11" Foreground="#b0b0b0" TextWrapping="Wrap"/>
                                        <TextBox x:Name="SettingsTrDiagnosticsPrivateKeyPathTextBox" Width="420" HorizontalAlignment="Left"/>
                                        <TextBlock Text="Private Key Passphrase" FontWeight="Bold"/>
                                        <TextBlock Text="Optional passphrase for the private key (stored securely)."
                                                   FontSize="11" Foreground="#b0b0b0" TextWrapping="Wrap"/>
                                        <TextBox x:Name="SettingsTrDiagnosticsPrivateKeyPassphraseTextBox" Width="260" HorizontalAlignment="Left"/>
                                        <TextBlock Text="Remote/Local Log Directory" FontWeight="Bold"/>
                                        <TextBlock Text="Raw trunk-recorder log directory used only when raw-log mode is selected."
                                                   FontSize="11" Foreground="#b0b0b0" TextWrapping="Wrap"/>
                                        <TextBox x:Name="SettingsTrDiagnosticsLogDirTextBox" Width="420" HorizontalAlignment="Left"/>
                                        <TextBlock Text="Local Diagnostics Cache" FontWeight="Bold"/>
                                        <TextBlock Text="Local cache directory for downloaded diagnostics artifacts."
                                                   FontSize="11" Foreground="#b0b0b0" TextWrapping="Wrap"/>
                                        <TextBox x:Name="SettingsTrDiagnosticsCachePathTextBox" Width="420" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Transcription">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Border Margin="12"
                                        Padding="14"
                                        Width="560"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Background="#232323"
                                        CornerRadius="8"
                                        BorderBrush="#3b3b3b"
                                        BorderThickness="1">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Transcription Model" FontWeight="Bold"/>
                                        <TextBlock Text="Speech model used to convert radio audio into text. Larger models are slower but usually more accurate."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"
                                                   TextWrapping="Wrap"/>
                                        <ComboBox x:Name="SettingsModelComboBox" Width="320">
                                            <ComboBoxItem Content="Default (engine default)" />
                                            <ComboBoxItem Content="whisper-tiny (74MB)" />
                                            <ComboBoxItem Content="whisper-base (142MB)" />
                                            <ComboBoxItem Content="whisper-small (466MB)" />
                                            <ComboBoxItem Content="whisper-medium (1.5GB)" />
                                            <ComboBoxItem Content="whisper-large-v3 (2.9GB)" />
                                            <ComboBoxItem Content="vosk-model-small-en-us-0.15 (50MB)" />
                                            <ComboBoxItem Content="vosk-model-en-us-0.22 (1.8GB)" />
                                            <ComboBoxItem Content="vosk-model-en-us-0.22-lgraph (128MB)" />
                                        </ComboBox>
                                        <TextBlock Text="Transcription Engine" FontWeight="Bold"/>
                                        <TextBlock Text="Inference runtime used by the selected model family (Whisper or Vosk)."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"
                                                   TextWrapping="Wrap"/>
                                        <ComboBox x:Name="SettingsEngineComboBox" Width="220">
                                            <ComboBoxItem Content="Whisper" />
                                            <ComboBoxItem Content="Vosk" />
                                        </ComboBox>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Content="Test"
                                                    Classes="menu-btn"
                                                    Width="120"
                                                    HorizontalAlignment="Left"
                                                    Click="OnTranscriptionTestClicked"/>
                                            <TextBlock Text="{Binding TranscriptionTestStatusText}"
                                                       VerticalAlignment="Center"
                                                       Foreground="#d0d0d0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Alerts">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Grid Margin="12"
                                      ColumnDefinitions="1*,3*"
                                      ColumnSpacing="12"
                                      VerticalAlignment="Top">
                                    <StackPanel Grid.Column="0" Spacing="12" VerticalAlignment="Top">
                                        <Border Padding="14"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Top"
                                                Background="#232323"
                                                CornerRadius="8"
                                                BorderBrush="#3b3b3b"
                                                BorderThickness="1">
                                            <StackPanel Spacing="10">
                                                <TextBlock Text="Email Provider" FontWeight="Bold"/>
                                                <TextBlock Text="Email service used to send test and alert notifications."
                                                           FontSize="11"
                                                           Foreground="#b0b0b0"
                                                           TextWrapping="Wrap"/>
                                                <ComboBox x:Name="SettingsEmailProviderComboBox"
                                                          Width="220"
                                                          HorizontalAlignment="Left">
                                                    <ComboBoxItem Content="Gmail" />
                                                    <ComboBoxItem Content="Yahoo" />
                                                </ComboBox>
                                                <TextBlock Text="Email Address" FontWeight="Bold"/>
                                                <TextBlock Text="Destination account for alerts and optional insights digest."
                                                           FontSize="11"
                                                           Foreground="#b0b0b0"
                                                           TextWrapping="Wrap"/>
                                                <TextBox x:Name="SettingsEmailUserTextBox"
                                                         HorizontalAlignment="Stretch"
                                                         HorizontalContentAlignment="Left"/>
                                                <TextBlock Text="App Password" FontWeight="Bold"/>
                                                <TextBlock Text="Provider-specific app password used for authenticated email sending."
                                                           FontSize="11"
                                                           Foreground="#b0b0b0"
                                                           TextWrapping="Wrap"/>
                                                <TextBox x:Name="SettingsEmailPasswordTextBox"
                                                         HorizontalAlignment="Stretch"
                                                         HorizontalContentAlignment="Left"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Padding="14"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Top"
                                                Background="#232323"
                                                CornerRadius="8"
                                                BorderBrush="#3b3b3b"
                                                BorderThickness="1">
                                            <StackPanel Spacing="10">
                                                <TextBlock Text="Alert Behavior" FontWeight="Bold"/>
                                                <TextBlock Text="Configure playback behavior for alert-matched calls."
                                                           FontSize="11"
                                                           Foreground="#b0b0b0"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="Autoplay Alerts" FontWeight="Bold"/>
                                                <TextBlock Text="Automatically play audio when a call matches an alert."
                                                           FontSize="11"
                                                           Foreground="#b0b0b0"
                                                           TextWrapping="Wrap"/>
                                                <CheckBox x:Name="SettingsAutoplayAlertsCheckBox" Content="Enable autoplay alerts"/>
                                                <TextBlock Text="Snooze Duration" FontWeight="Bold"/>
                                                <TextBlock Text="Default snooze duration used when temporarily muting alert autoplay."
                                                           FontSize="11"
                                                           Foreground="#b0b0b0"
                                                           TextWrapping="Wrap"/>
                                                <ComboBox x:Name="SettingsSnoozeComboBox" Width="140" HorizontalAlignment="Left">
                                                    <ComboBoxItem Content="5 minutes" />
                                                    <ComboBoxItem Content="15 minutes" />
                                                    <ComboBoxItem Content="30 minutes" />
                                                    <ComboBoxItem Content="1 hour" />
                                                </ComboBox>
                                                <TextBlock Text="Test Email" FontWeight="Bold"/>
                                                <TextBlock Text="Send a test message using the current email provider settings."
                                                           FontSize="11"
                                                           Foreground="#b0b0b0"
                                                           TextWrapping="Wrap"/>
                                                <Button Content="Test" Classes="menu-btn" Width="120" HorizontalAlignment="Left" Click="OnSettingsTestEmailClicked"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Padding="10"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top"
                                            Background="#1d1d1d"
                                            CornerRadius="8"
                                            BorderBrush="#3b3b3b"
                                            BorderThickness="1">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="Alert Manager" FontWeight="Bold"/>
                                            <TextBlock Text="Manage rules, matching behavior, and alert scope."
                                                       FontSize="11"
                                                       Foreground="#b0b0b0"
                                                       TextWrapping="Wrap"/>
                                            <ContentControl Content="{Binding AlertsPanelControl}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Talkgroups">
                            <Border Margin="12"
                                    Padding="14"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="#232323"
                                    CornerRadius="8"
                                    BorderBrush="#3b3b3b"
                                    BorderThickness="1">
                                <Grid RowDefinitions="Auto,*"
                                      RowSpacing="10"
                                      IsEnabled="{Binding IsTalkgroupEditorBusy, Converter={StaticResource InvertedBoolConverter}}">
                                        <WrapPanel Grid.Row="0"
                                                   Orientation="Horizontal">
                                            <TextBlock Text="CSV:"
                                                       Margin="0,0,8,8"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                            <Button Content="Import"
                                                    Classes="menu-btn"
                                                    Margin="0,0,8,8"
                                                    Click="OnSettingsImportTalkgroupsClicked"/>
                                            <Button Content="Build"
                                                    Classes="menu-btn"
                                                    Margin="0,0,8,8"
                                                    Click="OnSettingsBuildTalkgroupsClicked"/>
                                            <Button Content="Apply"
                                                    Classes="menu-btn"
                                                    Margin="0,0,8,8"
                                                    Click="OnTalkgroupApplyClicked"
                                                    IsEnabled="{Binding IsTalkgroupApplyEnabled}"/>
                                            <TextBlock Text="|"
                                                       Margin="0,0,8,8"
                                                       VerticalAlignment="Center"
                                                       Foreground="#8a8a8a"/>
                                            <TextBlock Text="Profile:"
                                                       Margin="0,0,8,8"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                            <ComboBox ItemsSource="{Binding TalkgroupEditableProfiles}"
                                                      SelectedItem="{Binding SelectedTalkgroupAddProfile, Mode=TwoWay}"
                                                      MinWidth="180"
                                                      Margin="0,0,8,8"
                                                      VerticalAlignment="Center"
                                                      IsEnabled="{Binding IsTalkgroupAddProfileEnabled}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate x:DataType="local:ProcessingProfile">
                                                        <TextBlock Text="{Binding Name}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <Button Content="Add Selected"
                                                    Classes="menu-btn"
                                                    Margin="0,0,8,8"
                                                    Click="OnAddSelectedTalkgroupsClicked"
                                                    IsEnabled="{Binding CanAddSelectedTalkgroups}"/>
                                            <TextBlock Text="|"
                                                       Margin="0,0,8,8"
                                                       VerticalAlignment="Center"
                                                       Foreground="#8a8a8a"/>
                                            <TextBlock Text="View:"
                                                       Margin="0,0,8,8"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                            <ComboBox ItemsSource="{Binding TalkgroupOpsCategoryFilterOptions}"
                                                      SelectedItem="{Binding SelectedTalkgroupOpsCategoryFilter, Mode=TwoWay}"
                                                      MinWidth="120"
                                                      Margin="0,0,8,8"
                                                      VerticalAlignment="Center"/>
                                            <TextBlock Text="Keyword:"
                                                       Margin="0,0,8,8"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                            <TextBox Width="160"
                                                     Margin="0,0,8,8"
                                                      VerticalAlignment="Center"
                                                      PlaceholderText="Filter talkgroups"
                                                      Text="{Binding TalkgroupKeywordFilter, Mode=TwoWay}"/>
                                            <StackPanel Spacing="2"
                                                        Width="280"
                                                        Margin="0,0,8,8"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TalkgroupCoverageText}"
                                                           Foreground="#aaddff"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </WrapPanel>
                                    <Border Grid.Row="1"
                                            Background="#1a1a1a"
                                            CornerRadius="6"
                                            Padding="6">
                                        <DataGrid x:Name="TalkgroupMappingsDataGrid"
                                                  Grid.Row="0"
                                                  IsEnabled="{Binding IsTalkgroupEditorBusy, Converter={StaticResource InvertedBoolConverter}}"
                                                  IsReadOnly="False"
                                                  ItemsSource="{Binding VisibleTalkgroupMappingRows}"
                                                  SelectionMode="Extended"
                                                  SelectionChanged="OnTalkgroupMappingsGridSelectionChanged"
                                                  VerticalAlignment="Stretch"
                                                  AutoGenerateColumns="False"
                                                  ColumnWidth="SizeToCells"
                                                  CanUserSortColumns="True"
                                                  GridLinesVisibility="Horizontal"
                                                  HeadersVisibility="Column">
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Width="68">
                                                        <DataGridTemplateColumn.Header>
                                                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                                                <CheckBox x:Name="TalkgroupSelectAllCheckBox"
                                                                          IsThreeState="True"
                                                                          VerticalAlignment="Center"
                                                                          HorizontalAlignment="Center"
                                                                          Click="OnTalkgroupSelectAllClicked"/>
                                                                <TextBlock Text="All"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="11"
                                                                           Foreground="#d0d0d0"/>
                                                            </StackPanel>
                                                        </DataGridTemplateColumn.Header>
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate x:DataType="local:TalkgroupMappingRow">
                                                                <CheckBox IsChecked="{Binding IsSelectedForProfile, Mode=TwoWay}"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          PointerPressed="OnTalkgroupSelectionCheckboxPointerPressed"
                                                                          Click="OnTalkgroupSelectionCheckboxClicked"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" SortMemberPath="Id" IsReadOnly="True"/>
                                                    <DataGridTextColumn Header="Mode" Binding="{Binding Mode}" SortMemberPath="Mode" IsReadOnly="True"/>
                                                    <DataGridTextColumn Header="Alpha" Binding="{Binding AlphaTag}" SortMemberPath="AlphaTag" IsReadOnly="True"/>
                                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" SortMemberPath="Description" IsReadOnly="True"/>
                                                    <DataGridTextColumn Header="RR Category" Binding="{Binding Category}" SortMemberPath="Category" IsReadOnly="True"/>
                                                    <DataGridTemplateColumn Header="Ops Category" SortMemberPath="OpsCategory">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate x:DataType="local:TalkgroupMappingRow">
                                                                <ComboBox ItemsSource="{Binding #RootWindow.TalkgroupOpsCategoryOptions}"
                                                                          SelectedItem="{Binding OpsCategory, Mode=TwoWay}"
                                                                          MinWidth="120"
                                                                          HorizontalAlignment="Stretch"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                                    <Border Grid.RowSpan="2"
                                            Background="#101010D8"
                                            IsVisible="{Binding IsTalkgroupEditorBusy}">
                                        <Border HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="#1c1c1c"
                                                BorderBrush="#5f5f5f"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="14,12">
                                            <StackPanel Spacing="10">
                                                <ProgressBar Width="240"
                                                             Height="6"
                                                             IsIndeterminate="True"/>
                                                <TextBlock Text="{Binding TalkgroupAutoResolveStatusText}"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Border>
                                </Grid>
                            </Border>
                        </TabItem>
                        <TabItem Header="Archives">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Grid Margin="12"
                                      ColumnDefinitions="600,16,420"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top">
                                    <Border Grid.Column="0"
                                            Padding="14"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top"
                                            Background="#232323"
                                            CornerRadius="8"
                                            BorderBrush="#3b3b3b"
                                            BorderThickness="1">
                                        <StackPanel Spacing="10">
                                            <CheckBox x:Name="SettingsArchiveEnabledCheckBox" Content="Enable SFTP archive source"/>
                                            <TextBlock Text="Remote Trunk Recorder archives are downloaded to a separate cache and loaded as an offline archive session."
                                                       FontSize="11"
                                                       Foreground="#b0b0b0"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="Host" FontWeight="Bold"/>
                                             <TextBox x:Name="SettingsArchiveHostTextBox" Width="320" HorizontalAlignment="Left" TextChanged="OnArchiveSecretFieldChanged"/>
                                            <TextBlock Text="Port" FontWeight="Bold"/>
                                             <TextBox x:Name="SettingsArchivePortTextBox" Width="100" HorizontalAlignment="Left" TextChanged="OnArchiveSecretFieldChanged"/>
                                            <TextBlock Text="Username" FontWeight="Bold"/>
                                             <TextBox x:Name="SettingsArchiveUsernameTextBox" Width="260" HorizontalAlignment="Left" TextChanged="OnArchiveSecretFieldChanged"/>
                                            <TextBlock Text="Authentication" FontWeight="Bold"/>
                                             <ComboBox x:Name="SettingsArchiveAuthModeComboBox" Width="180" HorizontalAlignment="Left" SelectionChanged="OnArchiveSecretSelectionChanged">
                                                <ComboBoxItem Content="Password" />
                                                <ComboBoxItem Content="Private key" />
                                            </ComboBox>
                                             <TextBlock Text="Password" FontWeight="Bold"/>
                                             <TextBox x:Name="SettingsArchivePasswordTextBox" Width="260" HorizontalAlignment="Left" TextChanged="OnArchiveSecretFieldChanged"/>
                                             <TextBlock Text="{Binding ArchiveSecretStatusText}"
                                                        FontSize="11"
                                                        Foreground="#9fc1dd"
                                                        TextWrapping="Wrap"/>
                                            <TextBlock Text="Private Key Path" FontWeight="Bold"/>
                                            <TextBox x:Name="SettingsArchivePrivateKeyPathTextBox" Width="420" HorizontalAlignment="Left"/>
                                            <TextBlock Text="Private Key Passphrase" FontWeight="Bold"/>
                                             <TextBox x:Name="SettingsArchivePrivateKeyPassphraseTextBox" Width="260" HorizontalAlignment="Left" TextChanged="OnArchiveSecretFieldChanged"/>
                                            <TextBlock Text="Remote Root" FontWeight="Bold"/>
                                             <TextBox x:Name="SettingsArchiveRemoteRootTextBox" Width="420" HorizontalAlignment="Left" TextChanged="OnArchiveSecretFieldChanged"/>
                                            <TextBlock Text="Local Archive Cache" FontWeight="Bold"/>
                                            <TextBox x:Name="SettingsArchiveCachePathTextBox" Width="420" HorizontalAlignment="Left"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Content="Test Connection"
                                                        Classes="menu-btn"
                                                        Width="150"
                                                        Click="OnArchiveTestConnectionClicked"/>
                                                <Button Content="Browse Archives"
                                                        Classes="menu-btn"
                                                        Width="150"
                                                        Click="OnArchiveBrowseClicked"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2"
                                            Padding="14"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top"
                                            Background="#1b2732"
                                            CornerRadius="8"
                                            BorderBrush="#355069"
                                            BorderThickness="1">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Archive behavior"
                                                       FontWeight="Bold"
                                                       Foreground="#d8ecff"/>
                                            <TextBlock Text="Downloaded archive data is kept separate from live/local captures."
                                                       FontSize="12"
                                                       Foreground="#d4e8f8"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="Live + Local reads the captures folder. Archive mode reads only the selected cache folder until you return to Live + Local."
                                                       FontSize="12"
                                                       Foreground="#9fc1dd"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding ArchiveCacheStatusText}"
                                                       FontSize="11"
                                                       Foreground="#9fc1dd"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Insights">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Grid Margin="12"
                                      ColumnDefinitions="600,16,744"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top">
                                    <Border Grid.Column="0"
                                            Padding="14"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top"
                                            Background="#232323"
                                            CornerRadius="8"
                                            BorderBrush="#3b3b3b"
                                            BorderThickness="1">
                                        <StackPanel Spacing="10">
                                            <CheckBox x:Name="SettingsLmLinkEnabledCheckBox" Content="Enable LM Link insights"/>
                                            <TextBlock Text="Turns on AI summary generation using an OpenAI-compatible LM Link endpoint."
                                                       FontSize="11"
                                                       Foreground="#b0b0b0"
                                                       TextWrapping="Wrap"/>
                                            <CheckBox x:Name="SettingsDailyDigestCheckBox" Content="Enable daily insights digest"/>
                                            <TextBlock Text="Sends a periodic digest email when LM Link and email settings are configured."
                                                       FontSize="11"
                                                       Foreground="#b0b0b0"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="Base URL" FontWeight="Bold"/>
                                            <TextBlock Text="HTTP endpoint root for LM Link."
                                                       FontSize="11"
                                                       Foreground="#b0b0b0"/>
                                            <TextBox x:Name="SettingsLmLinkBaseUrlTextBox" Width="420" HorizontalAlignment="Left"/>
                                            <TextBlock Text="Model" FontWeight="Bold"/>
                                            <TextBlock Text="Model identifier sent with LM Link requests."
                                                       FontSize="11"
                                                       Foreground="#b0b0b0"/>
                                            <TextBox x:Name="SettingsLmLinkModelTextBox" Width="280" HorizontalAlignment="Left"/>
                                            <TextBlock Text="API Key" FontWeight="Bold"/>
                                            <TextBlock Text="Optional token used to authenticate to LM Link."
                                                       FontSize="11"
                                                       Foreground="#b0b0b0"/>
                                            <TextBox x:Name="SettingsLmLinkApiKeyTextBox" Width="280" HorizontalAlignment="Left"/>
                                            <TextBlock Text="Timeout (ms)" FontWeight="Bold"/>
                                            <TextBlock Text="Maximum time to wait for each LM Link request before failing."
                                                       FontSize="11"
                                                       Foreground="#b0b0b0"
                                                       TextWrapping="Wrap"/>
                                            <TextBox x:Name="SettingsLmLinkTimeoutTextBox" Width="100" HorizontalAlignment="Left"/>
                                            <TextBlock Text="Retries" FontWeight="Bold"/>
                                            <TextBlock Text="Number of retry attempts after a failed LM Link request."
                                                       FontSize="11"
                                                       Foreground="#b0b0b0"
                                                       TextWrapping="Wrap"/>
                                            <TextBox x:Name="SettingsLmLinkRetriesTextBox" Width="80" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Padding="14"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top"
                                            Background="#1b2732"
                                            CornerRadius="8"
                                            BorderBrush="#355069"
                                            BorderThickness="1">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="LM Usage Ledger"
                                                       FontWeight="Bold"
                                                       Foreground="#d8ecff"/>
                                            <TextBlock Text="{Binding LmUsageLedgerPath, StringFormat='Ledger: {0}'}"
                                                       FontSize="11"
                                                       Foreground="#9fc1dd"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding LmUsageTierText}"
                                                       FontSize="11"
                                                       Foreground="#9fc1dd"
                                                       TextWrapping="Wrap"/>
                                            <Grid ColumnDefinitions="*,*"
                                                  RowDefinitions="Auto,Auto"
                                                  ColumnSpacing="8"
                                                  RowSpacing="8">
                                                <Border Grid.Row="0" Grid.Column="0" Background="#203445" CornerRadius="6" Padding="8">
                                                    <TextBlock Text="{Binding LmUsage24hText}" Foreground="#d4e8f8" TextWrapping="Wrap"/>
                                                </Border>
                                                <Border Grid.Row="0" Grid.Column="1" Background="#203445" CornerRadius="6" Padding="8">
                                                    <TextBlock Text="{Binding LmUsage2dText}" Foreground="#d4e8f8" TextWrapping="Wrap"/>
                                                </Border>
                                                <Border Grid.Row="1" Grid.Column="0" Background="#203445" CornerRadius="6" Padding="8">
                                                    <TextBlock Text="{Binding LmUsageWeekText}" Foreground="#d4e8f8" TextWrapping="Wrap"/>
                                                </Border>
                                                <Border Grid.Row="1" Grid.Column="1" Background="#203445" CornerRadius="6" Padding="8">
                                                    <TextBlock Text="{Binding LmUsageMonthText}" Foreground="#d4e8f8" TextWrapping="Wrap"/>
                                                </Border>
                                            </Grid>
                                            <Border BorderBrush="#2f465c"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="0"
                                                    Background="#16232f">
                                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                              VerticalScrollBarVisibility="Auto"
                                                              MaxHeight="520">
                                                    <DataGrid ItemsSource="{Binding LmUsageLedgerRows}"
                                                              AutoGenerateColumns="False"
                                                              HeadersVisibility="Column"
                                                              IsReadOnly="True"
                                                              CanUserSortColumns="False"
                                                              CanUserResizeColumns="True"
                                                              GridLinesVisibility="Horizontal"
                                                              MinHeight="220">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="120"/>
                                                            <DataGridTextColumn Header="Trigger" Binding="{Binding Trigger}" Width="160"/>
                                                            <DataGridTextColumn Header="Prompt Tok" Binding="{Binding PromptTokensDisplay}" Width="90"/>
                                                            <DataGridTextColumn Header="Comp Tok" Binding="{Binding CompletionTokensDisplay}" Width="90"/>
                                                            <DataGridTextColumn Header="Total Tok" Binding="{Binding TotalTokensDisplay}" Width="90"/>
                                                            <DataGridTextColumn Header="Std $" Binding="{Binding CostStandardDisplay}" Width="70"/>
                                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="60"/>
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </ScrollViewer>
                                            </Border>
                                            <TextBlock Text="No LM Link usage recorded yet."
                                                       IsVisible="{Binding HasLmUsageLedgerRows, Converter={StaticResource InvertedBoolConverter}}"
                                                       FontSize="12"
                                                       Foreground="#9fc1dd"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Cleanup">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Border Margin="12"
                                        Padding="10"
                                        Width="700"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Background="#1d1d1d"
                                        CornerRadius="8"
                                        BorderBrush="#3b3b3b"
                                        BorderThickness="1">
                                    <ContentControl Content="{Binding CleanupPanelControl}"/>
                                </Border>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="View">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Border Margin="12"
                                        Padding="14"
                                        Width="560"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Background="#232323"
                                        CornerRadius="8"
                                        BorderBrush="#3b3b3b"
                                        BorderThickness="1">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Text Size" FontWeight="Bold"/>
                                        <TextBlock Text="Adjust global UI font size for better readability."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Content="A-" Classes="menu-btn" Click="OnDecreaseFontSizeClicked"/>
                                            <Button Content="A+" Classes="menu-btn" Click="OnIncreaseFontSizeClicked"/>
                                        </StackPanel>

                                        <TextBlock Text="Preview"
                                                   FontWeight="Bold"
                                                   Margin="0,8,0,0"/>
                                        <TextBlock Text="Sample call card updates live as you change text size."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"
                                                   TextWrapping="Wrap"/>
                                        <Border Background="#1f2f3d"
                                                BorderBrush="#36566f"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10"
                                                Margin="0,2,0,0">
                                            <StackPanel Spacing="6">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Border Background="#8a63d2"
                                                            CornerRadius="4"
                                                            Padding="4,1">
                                                        <TextBlock Text="OTHER"
                                                                   FontSize="{DynamicResource CurrentFontSize}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#000000"/>
                                                    </Border>
                                                    <TextBlock Text="11:42 PM"
                                                               FontSize="{DynamicResource CurrentFontSize}"
                                                               Foreground="#cfe7ff"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="Mahan Gap Response"
                                                           FontSize="{DynamicResource CurrentFontSize}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#ffffff"/>
                                                <TextBlock Text="Unit advised possible road hazard near Harrison Pike. Monitoring for additional traffic-related updates."
                                                           FontSize="{DynamicResource CurrentFontSize}"
                                                           Foreground="#d4d4d4"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Profiles">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Border Margin="12"
                                        Padding="14"
                                        Width="560"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Background="#232323"
                                        CornerRadius="8"
                                        BorderBrush="#3b3b3b"
                                        BorderThickness="1">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Active Profile" FontWeight="Bold"/>
                                        <TextBlock Text="Profile controls which categories and talkgroups are visible and processed."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"
                                                   TextWrapping="Wrap"/>
                                        <ComboBox Width="260"
                                                  ItemsSource="{Binding Profiles}"
                                                  SelectedItem="{Binding ProfileEditorSelectedProfile, Mode=TwoWay}"
                                                  SelectionChanged="OnProfileEditorSelectionChanged">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="local:ProcessingProfile">
                                                    <TextBlock Text="{Binding Name}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBlock Text="Create Profile" FontWeight="Bold"/>
                                        <TextBlock Text="Create named profile presets for different monitoring scenarios."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"
                                                   TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBox x:Name="ProfileNameTextBox" Width="180" PlaceholderText="New profile name"/>
                                            <Button Content="Create" Classes="menu-btn" Click="OnCreateProfileClicked"/>
                                        </StackPanel>
                                        <TextBlock Text="Included Categories" FontWeight="Bold"/>
                                        <TextBlock Text="Choose which category menus and filters are enabled for this profile."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"
                                                   TextWrapping="Wrap"/>
                                        <WrapPanel ItemWidth="120">
                                            <CheckBox x:Name="ProfileIncludePoliceCheckBox" Content="Police" IsChecked="True"/>
                                            <CheckBox x:Name="ProfileIncludeFireCheckBox" Content="Fire" IsChecked="True"/>
                                            <CheckBox x:Name="ProfileIncludeEmsCheckBox" Content="EMS" IsChecked="True"/>
                                            <CheckBox x:Name="ProfileIncludeTrafficCheckBox" Content="Traffic" IsChecked="True"/>
                                            <CheckBox x:Name="ProfileIncludeOtherCheckBox" Content="Other" IsChecked="True"/>
                                        </WrapPanel>
                                        <TextBlock Text="Allowed Talkgroups" FontWeight="Bold"/>
                                        <TextBlock Text="Comma-separated talkgroup IDs. Leave blank to allow all talkgroups."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"
                                                   TextWrapping="Wrap"/>
                                        <TextBox x:Name="ProfileTalkgroupsTextBox" Width="420"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Content="Update"
                                                    Classes="menu-btn"
                                                    Width="140"
                                                    Click="OnUpdateProfileClicked"
                                                    IsEnabled="{Binding HasProfileEditorSelection}"/>
                                            <Button Content="Delete"
                                                    Classes="menu-btn"
                                                    Width="140"
                                                    Click="OnDeleteProfileClicked"
                                                    IsEnabled="{Binding CanDeleteSelectedProfile}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Grid>

            <!-- Troubleshoot -->
            <Grid Grid.Row="1"
                  Grid.Column="0"
                  IsVisible="{Binding IsTroubleshootSectionVisible}">
                <TabControl Margin="8"
                            SelectionChanged="OnTroubleshootTabSelectionChanged">
                    <TabItem Header="Pizzapi">
                        <Grid RowDefinitions="Auto,*" Margin="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Trace level:" VerticalAlignment="Center" Foreground="#d0d0d0"/>
                                <ComboBox Width="180"
                                          ItemsSource="{Binding TroubleshootTraceLevelOptions}"
                                          SelectedItem="{Binding SelectedTroubleshootTraceLevel, Mode=TwoWay}"/>
                                <TextBlock Text="Pizzapi log:" VerticalAlignment="Center" Foreground="#d0d0d0"/>
                                <ComboBox Width="360"
                                          ItemsSource="{Binding PizzaPiLogOptions}"
                                          SelectedItem="{Binding SelectedPizzaPiLogOption, Mode=TwoWay}"/>
                            </StackPanel>
                            <TextBox Grid.Row="1"
                                     Margin="0,8,0,0"
                                     Text="{Binding PizzaPiLogText}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"/>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Trunk Recorder" IsEnabled="{Binding IsTrunkTroubleshootVisible}">
                        <Grid RowDefinitions="Auto,*" Margin="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Refresh Health" Classes="menu-btn" Click="OnRefreshTrHealthClicked"
                                        IsEnabled="{Binding IsTrTroubleshootControlsEnabled}"/>
                                <CheckBox Content="Use raw logs (slower; may take time to download/parse)"
                                          IsChecked="{Binding ForceRawLogDiagnostics, Mode=TwoWay}"
                                          VerticalAlignment="Center"
                                          IsEnabled="{Binding IsTrTroubleshootControlsEnabled}"/>
                                <TextBlock Text="Loading diagnostics and metrics..."
                                           VerticalAlignment="Center"
                                           Foreground="#f0c674"
                                           IsVisible="{Binding IsTrTroubleshootLoading}"/>
                            </StackPanel>
                            <TabControl Grid.Row="1"
                                        Margin="0,8,0,0"
                                        IsEnabled="{Binding IsTrTroubleshootControlsEnabled}"
                                        SelectionChanged="OnTrunkTroubleshootTabSelectionChanged">
                                <TabItem Header="Health Summary">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel Margin="8" Spacing="12">
                                            <StackPanel Spacing="3">
                                                <TextBlock Text="{Binding TrunkRecorderHealthTitle}" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding TrunkRecorderHealthWindow}" Foreground="#b0b0b0"/>
                                                <TextBlock Text="Health summary is computed from the last 24 hours only." Foreground="#ffcf9f"/>
                                                <TextBlock Text="{Binding TrunkRecorderHealthLastWindow}" Foreground="#b0b0b0"/>
                                                <TextBlock Text="{Binding TrunkRecorderHealthSource}" Foreground="#8f8f8f" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <DataGrid ItemsSource="{Binding TrHealthMetrics}"
                                                      AutoGenerateColumns="False"
                                                      IsReadOnly="True"
                                                      CanUserSortColumns="False"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      MinHeight="220">
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Header="Metric" Width="220">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate x:DataType="local:TrHealthMetricRow">
                                                                <Border Background="{Binding IsIssue, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#4a2a2a|Transparent'}" Padding="4,2">
                                                                    <TextBlock Text="{Binding Metric}"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Value" Width="140">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate x:DataType="local:TrHealthMetricRow">
                                                                <Border Background="{Binding IsIssue, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#4a2a2a|Transparent'}" Padding="4,2">
                                                                    <TextBlock Text="{Binding Value}"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Notes" Width="*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate x:DataType="local:TrHealthMetricRow">
                                                                <Border Background="{Binding IsIssue, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#4a2a2a|Transparent'}" Padding="4,2">
                                                                    <TextBlock Text="{Binding Notes}" TextWrapping="Wrap"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                            <TextBlock Text="Systems" FontSize="15" FontWeight="SemiBold"/>
                                            <DataGrid ItemsSource="{Binding TrHealthSystemRows}"
                                                      AutoGenerateColumns="False"
                                                      IsReadOnly="True"
                                                      CanUserSortColumns="False"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      MinHeight="120">
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Header="System" Width="220">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate x:DataType="local:TrHealthMetricRow">
                                                                <Border Background="{Binding IsIssue, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#4a2a2a|Transparent'}" Padding="4,2">
                                                                    <TextBlock Text="{Binding Metric}"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Health" Width="160">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate x:DataType="local:TrHealthMetricRow">
                                                                <Border Background="{Binding IsIssue, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#4a2a2a|Transparent'}" Padding="4,2">
                                                                    <TextBlock Text="{Binding Value}"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Details" Width="*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate x:DataType="local:TrHealthMetricRow">
                                                                <Border Background="{Binding IsIssue, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#4a2a2a|Transparent'}" Padding="4,2">
                                                                    <TextBlock Text="{Binding Notes}" TextWrapping="Wrap"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                            <TextBlock Text="Suggested Remedies" FontSize="15" FontWeight="SemiBold"/>
                                            <ItemsControl ItemsSource="{Binding TrHealthRemedyRows}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#242424" BorderBrush="#3b3b3b" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,6">
                                                            <StackPanel Spacing="3">
                                                                <TextBlock Text="{Binding Metric}" FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding Notes}" TextWrapping="Wrap" Foreground="#d0d0d0"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>
                                <TabItem Header="Metrics">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel Margin="8" Spacing="12">
                                            <TextBlock Text="Hourly Trends and Baselines" FontSize="15" FontWeight="SemiBold"/>
                                            <TextBlock Text="Baselines appear as dotted lines." Foreground="#b0b0b0"/>
                                            <StackPanel Orientation="Horizontal" Spacing="16">
                                                <CheckBox Content="By system" IsChecked="{Binding TrHealthShowBySystem, Mode=TwoWay}"/>
                                                <CheckBox Content="Use persisted baseline history" IsChecked="{Binding UsePersistedBaselineHistory, Mode=TwoWay}"/>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="Compare against baseline" VerticalAlignment="Center" Foreground="#d0d0d0"/>
                                                    <ComboBox Width="120"
                                                              ItemsSource="{Binding TrHealthBaselineOptions}"
                                                              SelectedItem="{Binding SelectedTrHealthBaseline, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{Binding TrHealthCharts}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#202020"
                                                                BorderBrush="#3b3b3b"
                                                                BorderThickness="1"
                                                                CornerRadius="6"
                                                                Padding="10"
                                                                Width="760"
                                                                HorizontalAlignment="Left"
                                                                Margin="0,0,12,12">
                                                            <Grid RowDefinitions="Auto,150,Auto,Auto" ColumnDefinitions="56,*">
                                                                <StackPanel Grid.ColumnSpan="2" Spacing="2">
                                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                                                    <TextBlock Text="{Binding YAxisLabel}" Foreground="#a8a8a8" FontSize="11"/>
                                                                </StackPanel>
                                                                <Grid Grid.Row="1" Grid.Column="0" RowDefinitions="Auto,*,Auto" Margin="0,14,6,18">
                                                                    <TextBlock Text="{Binding MaxLabel}" FontSize="11" HorizontalAlignment="Right"/>
                                                                    <TextBlock Grid.Row="1" Text="{Binding YTick3Label}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,24,0,0" Foreground="#a8a8a8"/>
                                                                    <TextBlock Grid.Row="1" Text="{Binding YTick2Label}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#a8a8a8"/>
                                                                    <TextBlock Grid.Row="1" Text="{Binding YTick1Label}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,24" Foreground="#a8a8a8"/>
                                                                    <TextBlock Grid.Row="2" Text="{Binding MinLabel}" FontSize="11" HorizontalAlignment="Right"/>
                                                                </Grid>
                                                                <Canvas Grid.Row="1" Grid.Column="1" Width="640" Height="140" ClipToBounds="True">
                                                                    <Line StartPoint="42,12" EndPoint="42,118" Stroke="#666" StrokeThickness="1"/>
                                                                    <Line StartPoint="42,118" EndPoint="620,118" Stroke="#666" StrokeThickness="1"/>
                                                                    <Line StartPoint="42,91.5" EndPoint="620,91.5" Stroke="#2f2f2f" StrokeThickness="1"/>
                                                                    <Line StartPoint="42,65" EndPoint="620,65" Stroke="#333" StrokeThickness="1"/>
                                                                    <Line StartPoint="42,38.5" EndPoint="620,38.5" Stroke="#2f2f2f" StrokeThickness="1"/>
                                                                    <Line StartPoint="42,118" EndPoint="42,123" Stroke="#666" StrokeThickness="1"/>
                                                                    <Line StartPoint="138.3,118" EndPoint="138.3,123" Stroke="#666" StrokeThickness="1"/>
                                                                    <Line StartPoint="234.7,118" EndPoint="234.7,123" Stroke="#666" StrokeThickness="1"/>
                                                                    <Line StartPoint="331.0,118" EndPoint="331.0,123" Stroke="#666" StrokeThickness="1"/>
                                                                    <Line StartPoint="427.3,118" EndPoint="427.3,123" Stroke="#666" StrokeThickness="1"/>
                                                                    <Line StartPoint="523.7,118" EndPoint="523.7,123" Stroke="#666" StrokeThickness="1"/>
                                                                    <Line StartPoint="620,118" EndPoint="620,123" Stroke="#666" StrokeThickness="1"/>
                                                                    <Polyline Points="{Binding Series1Points}" Stroke="#62c6ff" StrokeThickness="2"/>
                                                                    <Polyline Points="{Binding Series2Points}" Stroke="#62c6ff" StrokeThickness="2" StrokeDashArray="4,4"/>
                                                                    <Polyline Points="{Binding Series3Points}" Stroke="#ffcf5a" StrokeThickness="2"/>
                                                                    <Polyline Points="{Binding Series4Points}" Stroke="#ffcf5a" StrokeThickness="2" StrokeDashArray="4,4"/>
                                                                    <Polyline Points="{Binding Series5Points}" Stroke="#7ee081" StrokeThickness="2"/>
                                                                    <Polyline Points="{Binding Series6Points}" Stroke="#7ee081" StrokeThickness="2" StrokeDashArray="4,4"/>
                                                                </Canvas>
                                                                <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,*,*,*,*,*,*" Margin="42,0,20,0">
                                                                    <TextBlock Grid.Column="0" Text="{Binding XTick0Label}" FontSize="11" Foreground="#a8a8a8" HorizontalAlignment="Left"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding XTick1Label}" FontSize="11" Foreground="#a8a8a8" HorizontalAlignment="Center"/>
                                                                    <TextBlock Grid.Column="2" Text="{Binding XTick2Label}" FontSize="11" Foreground="#a8a8a8" HorizontalAlignment="Center"/>
                                                                    <TextBlock Grid.Column="3" Text="{Binding XTick3Label}" FontSize="11" Foreground="#a8a8a8" HorizontalAlignment="Center"/>
                                                                    <TextBlock Grid.Column="4" Text="{Binding XTick4Label}" FontSize="11" Foreground="#a8a8a8" HorizontalAlignment="Center"/>
                                                                    <TextBlock Grid.Column="5" Text="{Binding XTick5Label}" FontSize="11" Foreground="#a8a8a8" HorizontalAlignment="Center"/>
                                                                    <TextBlock Grid.Column="6" Text="{Binding EndLabel}" FontSize="11" Foreground="#a8a8a8" HorizontalAlignment="Right"/>
                                                                </Grid>
                                                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="12" Margin="0,6,0,0">
                                                                    <StackPanel.IsVisible>
                                                                        <Binding Path="HasLegend"/>
                                                                    </StackPanel.IsVisible>
                                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                                        <StackPanel.IsVisible>
                                                                            <Binding Path="Series1Label" Converter="{StaticResource StringHasTextConverter}"/>
                                                                        </StackPanel.IsVisible>
                                                                        <Border Width="16" Height="3" Background="#62c6ff" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding Series1Label}" FontSize="11" Foreground="#d0d0d0"/>
                                                                    </StackPanel>
                                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                                        <StackPanel.IsVisible>
                                                                            <Binding Path="Series2Label" Converter="{StaticResource StringHasTextConverter}"/>
                                                                        </StackPanel.IsVisible>
                                                                        <Border Width="16" Height="3" Background="#62c6ff" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding Series2Label}" FontSize="11" Foreground="#d0d0d0"/>
                                                                    </StackPanel>
                                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                                        <StackPanel.IsVisible>
                                                                            <Binding Path="Series3Label" Converter="{StaticResource StringHasTextConverter}"/>
                                                                        </StackPanel.IsVisible>
                                                                        <Border Width="16" Height="3" Background="#ffcf5a" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding Series3Label}" FontSize="11" Foreground="#d0d0d0"/>
                                                                    </StackPanel>
                                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                                        <StackPanel.IsVisible>
                                                                            <Binding Path="Series4Label" Converter="{StaticResource StringHasTextConverter}"/>
                                                                        </StackPanel.IsVisible>
                                                                        <Border Width="16" Height="3" Background="#ffcf5a" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding Series4Label}" FontSize="11" Foreground="#d0d0d0"/>
                                                                    </StackPanel>
                                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                                        <StackPanel.IsVisible>
                                                                            <Binding Path="Series5Label" Converter="{StaticResource StringHasTextConverter}"/>
                                                                        </StackPanel.IsVisible>
                                                                        <Border Width="16" Height="3" Background="#7ee081" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding Series5Label}" FontSize="11" Foreground="#d0d0d0"/>
                                                                    </StackPanel>
                                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                                        <StackPanel.IsVisible>
                                                                            <Binding Path="Series6Label" Converter="{StaticResource StringHasTextConverter}"/>
                                                                        </StackPanel.IsVisible>
                                                                        <Border Width="16" Height="3" Background="#7ee081" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding Series6Label}" FontSize="11" Foreground="#d0d0d0"/>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>
                                <TabItem Header="Log Output">
                                    <TextBox Text="{Binding TrunkRecorderLogText}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"/>
                                </TabItem>
                                <TabItem Header="Diagnostics">
                                    <TextBox Text="{Binding TrunkRecorderDiagnosticsText}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"/>
                                </TabItem>
                                <TabItem Header="Insights" IsEnabled="{Binding IsTrHealthInsightsEnabled}">
                                    <Grid RowDefinitions="Auto,*" Margin="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Content="Generate Recommendation"
                                                    Classes="menu-btn"
                                                    Click="OnGenerateTrHealthInsightsClicked"
                                                    IsEnabled="{Binding CanGenerateTrHealthInsights}"/>
                                            <TextBlock Text="Uses LM Link to summarize issues and baselines."
                                                       Foreground="#b0b0b0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBox Grid.Row="1"
                                                 Margin="0,8,0,0"
                                                 Text="{Binding TrHealthInsightsText}"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"/>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <!-- Footer Status (bottom) -->
        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#222"
                Padding="8"
                BorderBrush="#444"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="0"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding FooterProfileText}" Foreground="#7dd3fc" FontSize="12"/>
                    <TextBlock Text="  |  " Foreground="#666666" FontSize="12"/>
                    <TextBlock Text="{Binding FooterCallsText}" Foreground="#ffffff" FontSize="12"/>
                    <TextBlock Text="  " Foreground="#666666" FontSize="12"/>
                    <TextBlock Text="{Binding FooterAlertsText}" Foreground="#ffb366" FontSize="12"/>
                    <TextBlock Text="  " Foreground="#666666" FontSize="12"/>
                    <TextBlock Text="{Binding FooterTokensText}" Foreground="#9ad67d" FontSize="12"/>
                    <TextBlock Text="  |  " Foreground="#666666" FontSize="12"/>
                    <TextBlock Text="{Binding FooterStatusText}"
                               Foreground="#d7d7d7"
                               FontSize="12"
                               ToolTip.Tip="{Binding FooterStatusText}"
                               TextTrimming="CharacterEllipsis"
                               Width="420"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="5,0,0,0">
                    <Border Background="{Binding TrServerPillBackground}"
                            BorderBrush="{Binding TrServerPillBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="8,2"
                            VerticalAlignment="Center"
                            ToolTip.Tip="{Binding TrServerToolTipText}">
                        <TextBlock Text="{Binding TrServerPillText}"
                                   Foreground="{Binding TrServerPillForeground}"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Text="{Binding VersionString}"
                               Foreground="#888"
                               FontSize="11"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Applying settings overlay -->
        <Grid Grid.Row="0"
              Grid.Column="0"
              Grid.RowSpan="2"
              Grid.ColumnSpan="1"
              IsVisible="{Binding IsApplyingSettings}"
              IsHitTestVisible="True"
              Panel.ZIndex="100">
            <Border Background="#80000000"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    IsHitTestVisible="True"/>
            <Border Background="#2a2a2a"
                    BorderBrush="#555"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="True">
                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="Applying settings..."
                               Foreground="White"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Width="220" Height="8"/>
                </StackPanel>
            </Border>
        </Grid>

        </Grid>
    </DockPanel>
</Window>

