<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:pizzapi"
        xmlns:models="using:pizzalib"
        xmlns:ToolTip="using:Avalonia.Controls"
        x:Class="pizzapi.MainWindow"
        x:DataType="local:MainWindow"
        Title="PizzaPi"
        Width="800"
        Height="600"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Icon="/images/logo.png"
        Loaded="OnWindowLoaded">
    <Window.Resources>
        <local:BoolToDoubleConverter x:Key="BoolToDoubleConverter" />
        <local:BoolToStringConverter x:Key="BoolToStringConverter" />
        <local:BoolToColorConverter x:Key="BoolToColorConverter" />
        <local:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        
        <!-- Dynamic button style with active state support -->
        <Style x:Key="TouchButtonStyle" Selector="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        
<!-- Active button style (orange) -->
        <Style x:Key="ActiveButtonStyle" Selector="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Background" Value="#ffaa00"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>


        
        <!-- Inactive button style (gray) -->
        <Style x:Key="InactiveButtonStyle" Selector="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Background" Value="#4a4a4a"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        
        <!-- Data template for group headers -->
        <DataTemplate x:Key="HeaderTemplate" x:DataType="local:CallGroupItem">
            <Button Background="#1a4a1a"
                    Margin="0,4,0,0"
                    Padding="0"
                    Cursor="Hand"
                    Click="OnGroupHeaderClicked"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Center"
                    Classes="header-button">
                <Button.Styles>
                    <Style Selector="Button.header-button">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="#1a4a1a"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                    <Style Selector="Button.header-button:pointerover">
                        <Setter Property="Background" Value="#2a5a2a"/>
                    </Style>
                    <Style Selector="Button.header-button:pressed">
                        <Setter Property="Background" Value="#3a6a3a"/>
                    </Style>
                </Button.Styles>
                <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Top">
                    <!-- Expand/Collapse chevron - use two paths with visibility toggle to prevent shift -->
                    <Grid Width="16" Height="16" VerticalAlignment="Top" Margin="4,-5,10,15">
                        <!-- Collapsed state: chevron pointing right -->
                        <Path Data="M8.59 16.58L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.42z"
                              Fill="#00ff00"
                              Width="16"
                              Height="16"
                              IsVisible="{Binding IsExpanded, Converter={StaticResource InvertedBoolConverter}}"/>
                        <!-- Expanded state: chevron pointing down -->
                        <Path Data="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"
                              Fill="#00ff00"
                              Width="16"
                              Height="16"
                              IsVisible="{Binding IsExpanded}"/>
                    </Grid>
                    <TextBlock Text="{Binding HeaderText}"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#00ff00"
                               VerticalAlignment="Top"/>
                </StackPanel>
            </Button>
        </DataTemplate>
        
		<!-- Data template for call items -->
<DataTemplate x:Key="CallTemplate" x:DataType="local:CallGroupItem">
    <Border Background="{Binding IsSearchMatch, Converter={StaticResource SearchHighlightConverter}, FallbackValue=Transparent}"
            BorderBrush="{Binding Call.IsCurrentMatch, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#ffa500,#555'}"
            BorderThickness="0,0,0,1"
            CornerRadius="0"
            Cursor="Hand"
            PointerReleased="OnCallRowClicked"
            HorizontalAlignment="Stretch"
            Margin="0,4,0,0">

        <Grid HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Talkgroup -->
            <TextBlock Grid.Row="0" Grid.ColumnSpan="7"
                       Text="{Binding Call.FriendlyTalkgroup}"
                       FontSize="{DynamicResource CurrentFontSize}"
                       FontWeight="Bold"
                       Foreground="#00d2ff"
                       IsVisible="{Binding ShowTalkgroup}"
					   Padding="10"
                       HorizontalAlignment="Left"/>

            <!-- Transcription - flush left to window edge, spans full width under icons -->
            <TextBlock Grid.Row="1" Grid.ColumnSpan="7"
                       Text="{Binding Call.Transcription}"
                       TextWrapping="Wrap"
                       FontSize="{DynamicResource CurrentFontSize}"
                       Foreground="{Binding IsSearchMatch, Converter={StaticResource SearchTextForegroundConverter}, FallbackValue=White}"
                       HorizontalAlignment="Left"
                       TextAlignment="Left"
                       Margin="0,0,0,0"/>

            <!-- Timestamp + Frequency -->
            <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{Binding Call.CallTime}" FontSize="11" Foreground="Gray"/>
                <TextBlock Text="{Binding Call.FriendlyFrequency}" FontSize="11" Foreground="#ffaa00"/>
            </StackPanel>

            <!-- PIN -->
            <Border Grid.Row="2" Grid.Column="2" Width="40" Height="32" VerticalAlignment="Center"
                    Background="Transparent" Cursor="Hand" PointerReleased="OnPinClicked"
                    ToolTip.Tip="Pin / unpin this call">
                <Border.Styles>
                    <Style Selector="Border:pointerover">
                        <Setter Property="Background" Value="#404040"/>
                    </Style>
                </Border.Styles>
                <Path Data="M16 12V4H17V2H7V4H8V12L6 14V16H11.2V22H12.8V16H18V14L16 12M8.8 14L10 12.8V4H14V12.8L15.2 14H8.8Z"
                      Fill="{Binding Call.IsPinned, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#ff6b6b|#666666'}"
                      Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                      IsHitTestVisible="False"/>
            </Border>

            <!-- SAVE -->
            <Border Grid.Row="2" Grid.Column="3" Width="40" Height="32" VerticalAlignment="Center"
                    Background="Transparent" Cursor="Hand" PointerReleased="OnSaveClicked"
                    ToolTip.Tip="Save audio + transcription">
                <Border.Styles>
                    <Style Selector="Border:pointerover">
                        <Setter Property="Background" Value="#404040"/>
                    </Style>
                </Border.Styles>
                <Path Data="M15 9H5V5H15M12 19A3 3 0 0 1 9 16A3 3 0 0 1 12 13A3 3 0 0 1 15 16A3 3 0 0 1 12 19M17 3H5C3.89 3 3 3.9 3 5V19A2 2 0 0 0 5 21H19A2 2 0 0 0 21 19V7L17 3Z"
                      Fill="#4CAF50" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                      IsHitTestVisible="False"/>
            </Border>

            <!-- COPY -->
            <Border Grid.Row="2" Grid.Column="4" Width="40" Height="32" VerticalAlignment="Center"
                    Background="Transparent" Cursor="Hand" PointerReleased="OnCopyClicked"
                    ToolTip.Tip="Copy transcription to clipboard">
                <Border.Styles>
                    <Style Selector="Border:pointerover">
                        <Setter Property="Background" Value="#404040"/>
                    </Style>
                </Border.Styles>
                <Path Data="M16 1H4C2.9 1 2 1.9 2 3V17H4V3H16V1M19 5H8C6.9 5 6 5.9 6 7V21C6 22.1 6.9 23 8 23H19C20.1 23 21 22.1 21 21V7C21 5.9 20.1 5 19 5M19 21H8V7H19V21Z"
                      Fill="#4CAF50" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                      IsHitTestVisible="False"/>
            </Border>

            <!-- PLAY / STOP -->
            <Border Grid.Row="2" Grid.Column="5" Width="40" Height="32" VerticalAlignment="Center"
                    Background="Transparent" Cursor="Hand" PointerReleased="OnCallRowClicked"
                    ToolTip.Tip="Play / stop audio">
                <Border.Styles>
                    <Style Selector="Border:pointerover">
                        <Setter Property="Background" Value="#404040"/>
                    </Style>
                </Border.Styles>
                <Grid Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Path Data="M8 5.14V19.14L19 12.14L8 5.14Z"
                          Fill="#4CAF50"
                          IsVisible="{Binding Call.IsAudioPlaying, Converter={StaticResource InvertedBoolConverter}}"/>
                    <Path Data="M6 6H18V18H6V6Z"
                          Fill="#f44336"
                          IsVisible="{Binding Call.IsAudioPlaying}"/>
                </Grid>
            </Border>

            <!-- Duration -->
            <TextBlock Grid.Row="2" Grid.Column="6" VerticalAlignment="Center"
                       FontSize="11" Foreground="#4CAF50" Margin="8,0,0,0">
                <TextBlock.Text>
                    <Binding Path="Call.Duration" StringFormat="{}{0}s"/>
                </TextBlock.Text>
            </TextBlock>
        </Grid>
    </Border>
</DataTemplate>

        <DataTemplate x:Key="InsightCategoryTemplate" x:DataType="local:InsightCategorySection">
            <StackPanel Spacing="4" Margin="0,4,0,6">
                <Button Background="{Binding AccentColor}"
                        Classes="insight-group-header"
                        CornerRadius="4"
                        Padding="8,4"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Click="OnInsightCategoryHeaderClicked">
                    <Button.Styles>
                        <Style Selector="Button.insight-group-header:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Style>
                        <Style Selector="Button.insight-group-header:pressed /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Style>
                    </Button.Styles>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Foreground="White" FontWeight="Bold" FontSize="12">
                            <Run Text="{Binding DisplayName}"/>
                            <Run Text=" "/>
                            <Run Text="("/>
                            <Run Text="{Binding VisibleEvents.Count}"/>
                            <Run Text="/"/>
                            <Run Text="{Binding TotalCount}"/>
                            <Run Text=")"/>
                        </TextBlock>
                    </StackPanel>
                </Button>
                <ItemsControl ItemsSource="{Binding VisibleEvents}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Left" Margin="0,6"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:InsightNotableEvent">
                            <Border Background="{Binding CategoryTileBackground}" BorderBrush="{Binding CategoryAccentColor}" BorderThickness="1" CornerRadius="4" Margin="3,4" Padding="5,4" Width="360">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                                    <StackPanel Grid.Row="0" Spacing="1">
                                        <SelectableTextBlock Text="{Binding DisplayTitle}"
                                                             Foreground="{Binding CategoryAccentColor}"
                                                             FontWeight="SemiBold"
                                                             FontSize="{DynamicResource InsightsTileFontSize}"
                                                             TextWrapping="Wrap"/>
                                        <SelectableTextBlock Text="{Binding TimestampDisplay}"
                                                             Foreground="#9ac7e8"
                                                             FontSize="{DynamicResource CurrentFontSize}"
                                                             Margin="0"
                                                             IsVisible="{Binding TimestampDisplay, Converter={StaticResource StringNotEmptyConverter}}"/>
                                        <SelectableTextBlock Text="{Binding Detail}"
                                                             Foreground="#dddddd"
                                                             FontSize="{DynamicResource InsightsTileFontSize}"
                                                             TextWrapping="Wrap"
                                                             Margin="0"/>
                                    </StackPanel>
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                            <Button Content="Transcript"
                                                    Classes="menu-btn"
                                                    Padding="8,4"
                                                    FontSize="12"
                                                    MinHeight="30"
                                                    Background="#2f2f2f"
                                                    Foreground="#7dd3fc"
                                                    IsVisible="{Binding CanOpenSources}"
                                                    Click="OnInsightTranscriptClicked"/>
                                            <Button Content="Audio"
                                                    Classes="menu-btn"
                                                    Padding="8,4"
                                                    FontSize="12"
                                                    MinHeight="30"
                                                    Background="#2f2f2f"
                                                    Foreground="#7dd3fc"
                                                    IsVisible="{Binding CanOpenSources}"
                                                    Click="OnInsightAudioClicked"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Margin="8,0,0,0" Width="30" Height="30" CornerRadius="15">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding Confidence, Converter={StaticResource ConfidenceColorConverter}}"/>
                                        </Border.Background>
                                        <TextBlock Text="{Binding ConfidencePercent}"
                                                   Foreground="#111111"
                                                   FontSize="9"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Classes="menu-btn"
                        Content="{Binding HiddenCount, StringFormat=Show more (+{0})}"
                        Padding="10,8"
                        MinHeight="40"
                        HorizontalAlignment="Left"
                        Margin="4,2,0,0"
                        Background="#303846"
                        Foreground="#b9d9ff"
                        IsVisible="{Binding HasHiddenEvents}"
                        Click="OnInsightShowMoreClicked"/>
                <Button Classes="menu-btn"
                        Content="Show fewer"
                        Padding="10,8"
                        MinHeight="40"
                        HorizontalAlignment="Left"
                        Margin="4,2,0,0"
                        Background="#303846"
                        Foreground="#b9d9ff"
                        IsVisible="{Binding CanShowFewer}"
                        Click="OnInsightShowFewerClicked"/>
            </StackPanel>
        </DataTemplate>

		        
<!-- Data template selector -->
        <local:CallGroupItemTemplateSelector x:Key="CallGroupTemplateSelector"
                                              HeaderTemplate="{StaticResource HeaderTemplate}"
                                              CallTemplate="{StaticResource CallTemplate}" />
        
        <!-- Search bar visibility converter -->
        <local:IntGreaterThanZeroConverter x:Key="IntGreaterThanZeroConverter"/>
        <local:SearchHighlightConverter x:Key="SearchHighlightConverter"/>
<local:SearchTextForegroundConverter x:Key="SearchTextForegroundConverter"/>
        <local:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
        <local:AlertSearchBackgroundConverter x:Key="AlertSearchBackgroundConverter"/>
        <local:ButtonActiveStateConverter x:Key="ButtonActiveStateConverter"/>
        <local:StringNotEmptyConverter x:Key="StringNotEmptyConverter"/>
        <local:ConfidenceColorConverter x:Key="ConfidenceColorConverter"/>
    </Window.Resources>

    <Window.Styles>
        <!-- Keep active/inactive menu button colors stable on hover/press -->
        <Style Selector="Button.menu-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"/>
        </Style>
        <Style Selector="Button.menu-btn:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"/>
        </Style>
    </Window.Styles>
    
    <DockPanel>
        <!-- Persistent Top Button Bar -->
        <Border Background="#333" 
                BorderBrush="#555" 
                BorderThickness="0,0,0,1"
                Padding="8,4"
                DockPanel.Dock="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <WrapPanel Grid.Column="0" Orientation="Horizontal" Classes="menu-row">
                <!-- Live Mode Button -->
                <Button Classes="menu-btn"
                        Height="44"
                        MinWidth="70"
                        Padding="12,8"
                        FontSize="13"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,0,6,6"
                        Background="{Binding IsRadioMode, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#00ff00,#4a4a4a'}"
                        Foreground="{Binding IsRadioMode, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        ToolTip.Tip="Switch to live mode (real-time monitoring)"
                        Click="OnLiveModeClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Width="16" Height="16"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M2,13 H4 V14 H2 Z M5,11 H7 V14 H5 Z M8,8 H10 V14 H8 Z M11,5 H13 V14 H11 Z"/>
                        <TextBlock Text="Radio" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Insights Button -->
                <Button Classes="menu-btn"
                        Height="44"
                        MinWidth="80"
                        Padding="12,8"
                        FontSize="13"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,0,6,6"
                        Background="{Binding IsInsightsMode, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#33aaff,#4a4a4a'}"
                        Foreground="{Binding IsInsightsMode, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        ToolTip.Tip="Show AI insights summaries"
                        IsEnabled="{Binding IsInsightsEnabled}"
                        Click="OnInsightsClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Width="14" Height="14"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M7,1.5 C4.7,1.5 2.9,3.3 2.9,5.6 C2.9,7.3 3.8,8.6 5.2,9.6 L5.2,11 L8.8,11 L8.8,9.6 C10.2,8.6 11.1,7.3 11.1,5.6 C11.1,3.3 9.3,1.5 7,1.5 Z M5.4,12.2 L8.6,12.2 L8.6,13.4 L5.4,13.4 Z M5.9,14.4 L8.1,14.4 L8.1,15.2 L5.9,15.2 Z"/>
                        <TextBlock Text="Insights" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- View Button -->
                <Button Classes="menu-btn" x:Name="ViewButton"
                        Height="44"
                        MinWidth="70"
                        Padding="12,8"
                        FontSize="13"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,0,6,6"
                        Background="{Binding IsViewPaneOpen, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#ff9900,#4a4a4a'}"
                        Foreground="{Binding IsViewPaneOpen, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        ToolTip.Tip="View options (sort, group, clear calls)"
                        Click="OnViewClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Width="14" Height="14"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M1,7 C2.6,4.6 4.8,3.4 7,3.4 C9.2,3.4 11.4,4.6 13,7 C11.4,9.4 9.2,10.6 7,10.6 C4.8,10.6 2.6,9.4 1,7 Z M7,5.2 A1.8,1.8 0 1 0 7,8.8 A1.8,1.8 0 1 0 7,5.2 Z"/>
                        <TextBlock Text="View" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Alerts Button -->
                <Button Classes="menu-btn"
                        Height="44"
                        MinWidth="70"
                        Padding="12,8"
                        FontSize="13"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,0,6,6"
                        Background="{Binding IsAlertsPaneOpen, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#ff9900,#4a4a4a'}"
                        Foreground="{Binding IsAlertsPaneOpen, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        ToolTip.Tip="Manage alert rules and notifications"
                        Click="OnAlertsClicked2">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Width="14" Height="14"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M7,1 C4.8,1 3,2.8 3,5 L3,8.5 L1.8,10.2 L1.8,11 L12.2,11 L12.2,10.2 L11,8.5 L11,5 C11,2.8 9.2,1 7,1 Z M5.8,12 C5.8,12.7 6.3,13.2 7,13.2 C7.7,13.2 8.2,12.7 8.2,12 Z"/>
                        <TextBlock Text="Alerts" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Settings Button -->
                <Button Classes="menu-btn"
                        Height="44"
                        MinWidth="70"
                        Padding="12,8"
                        FontSize="13"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,0,6,6"
                        Background="{Binding IsSettingsPaneOpen, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#ff9900,#4a4a4a'}"
                        Foreground="{Binding IsSettingsPaneOpen, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        ToolTip.Tip="Configure application settings"
                        Click="OnSettingsClicked2">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Width="14" Height="14"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M7,1.5 L8,1.5 L8.3,2.8 C8.7,2.9 9,3 9.3,3.2 L10.5,2.5 L11.2,3.2 L10.5,4.4 C10.7,4.7 10.8,5 10.9,5.4 L12.2,5.7 L12.2,6.7 L10.9,7 C10.8,7.4 10.7,7.7 10.5,8 L11.2,9.2 L10.5,9.9 L9.3,9.2 C9,9.4 8.7,9.5 8.3,9.6 L8,10.9 L7,10.9 L6.7,9.6 C6.3,9.5 6,9.4 5.7,9.2 L4.5,9.9 L3.8,9.2 L4.5,8 C4.3,7.7 4.2,7.4 4.1,7 L2.8,6.7 L2.8,5.7 L4.1,5.4 C4.2,5 4.3,4.7 4.5,4.4 L3.8,3.2 L4.5,2.5 L5.7,3.2 C6,3 6.3,2.9 6.7,2.8 Z M7.5,4.6 A1.6,1.6 0 1 0 7.5,7.8 A1.6,1.6 0 1 0 7.5,4.6 Z"/>
                        <TextBlock Text="Settings" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Cleanup Button -->
                <Button Classes="menu-btn"
                        Height="44"
                        MinWidth="70"
                        Padding="12,8"
                        FontSize="13"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,0,6,6"
                        Background="{Binding IsCleanupPaneOpen, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#ff9900,#4a4a4a'}"
                        Foreground="{Binding IsCleanupPaneOpen, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        ToolTip.Tip="Clean up captured audio files"
                        Click="OnCleanupClicked2">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Width="14" Height="14"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M2,4 L11,4 L10.2,12.5 L2.8,12.5 Z M4,2.5 L6,2.5 L6.6,2 L8,2 L8,3 L11,3 L11,4 L2,4 L2,3 L4,3 Z M4,5.5 L5,5.5 L5,11 L4,11 Z M6.5,5.5 L7.5,5.5 L7.5,11 L6.5,11 Z M9,5.5 L10,5.5 L10,11 L9,11 Z"/>
                        <TextBlock Text="Cleanup" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Exit Button -->
                <Button Classes="menu-btn"
                        Height="44"
                        MinWidth="70"
                        Padding="12,8"
                        FontSize="13"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,0,6,6"
                        Background="#4a4a4a"
                        Foreground="White"
                        ToolTip.Tip="Exit application"
                        Click="OnExitClicked2">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Width="14" Height="14"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M2.5,2.5 L11.5,11.5 M11.5,2.5 L2.5,11.5"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.8"/>
                        <TextBlock Text="Exit" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                </WrapPanel>

                <!-- Search (top right) -->
                <Grid Grid.Column="1"
                      VerticalAlignment="Center"
                      Margin="8,0,0,0"
                      IsVisible="{Binding IsCallsMode}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchTextBox"
                             Grid.Column="0"
                             Width="160"
                             Height="22"
                             Background="#1a1a1a"
                             Foreground="White"
                             BorderBrush="#333"
                             BorderThickness="1"
                             CornerRadius="4"
                             Padding="6,0"
                             FontSize="11"
                             PlaceholderText="Search..."
                             TextChanged="OnSearchTextChanged"
                             KeyDown="OnSearchTextBoxKeyDown"
                             LostFocus="OnSearchTextBoxLostFocus"/>
                </Grid>
</Grid>
        </Border>
        
        <!-- Time Range Sub-Menu (Radio) -->
        <Border Background="#2b2b2b"
                BorderBrush="#555"
                BorderThickness="0,0,0,1"
                Padding="6,4"
                DockPanel.Dock="Top"
                IsVisible="{Binding IsRadioSubmenuVisible}">
            <WrapPanel Orientation="Horizontal" Classes="menu-row">
                <Button Classes="menu-btn" Content="24h"
                        Margin="0,0,6,0"
                        Background="{Binding IsRange24hActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#00ff00,#4a4a4a'}"
                        Foreground="{Binding IsRange24hActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnRange24hClicked"/>
                <Button Classes="menu-btn" Content="2d"
                        Margin="0,0,6,0"
                        Background="{Binding IsRange2dActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#00ff00,#4a4a4a'}"
                        Foreground="{Binding IsRange2dActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnRange2dClicked"/>
                <Button Classes="menu-btn" Content="Week"
                        Margin="0,0,6,0"
                        Background="{Binding IsRangeWeekActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#00ff00,#4a4a4a'}"
                        Foreground="{Binding IsRangeWeekActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnRangeWeekClicked"/>
                <Button Classes="menu-btn" Content="Range"
                        Margin="0,0,6,0"
                        Background="{Binding IsRangeCustomActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#00ff00,#4a4a4a'}"
                        Foreground="{Binding IsRangeCustomActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnPickRangeClicked"/>
            </WrapPanel>
        </Border>

        <!-- Time Range Sub-Menu (Insights) -->
        <Border Background="#2b2b2b"
                BorderBrush="#555"
                BorderThickness="0,0,0,1"
                Padding="6,4"
                DockPanel.Dock="Top"
                IsVisible="{Binding IsInsightsSubmenuVisible}">
            <WrapPanel Orientation="Horizontal" Classes="menu-row">
                <Button Classes="menu-btn" Content="Today"
                        Margin="0,0,6,0"
                        Background="{Binding IsInsightsTodayActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#33aaff,#4a4a4a'}"
                        Foreground="{Binding IsInsightsTodayActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnInsightsTodayClicked"
                        IsEnabled="{Binding InsightsLoading, Converter={StaticResource InvertedBoolConverter}}"/>
                <Button Classes="menu-btn" Content="24h"
                        Margin="0,0,6,0"
                        Background="{Binding IsInsights24hActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#33aaff,#4a4a4a'}"
                        Foreground="{Binding IsInsights24hActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnInsights24hClicked"
                        IsEnabled="{Binding InsightsLoading, Converter={StaticResource InvertedBoolConverter}}"/>
                <Button Classes="menu-btn" Content="2d"
                        Margin="0,0,6,0"
                        Background="{Binding IsInsights2dActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#33aaff,#4a4a4a'}"
                        Foreground="{Binding IsInsights2dActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnInsights2dClicked"
                        IsEnabled="{Binding InsightsLoading, Converter={StaticResource InvertedBoolConverter}}"/>
                <Button Classes="menu-btn" Content="Week"
                        Margin="0,0,6,0"
                        Background="{Binding IsInsightsWeekActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#33aaff,#4a4a4a'}"
                        Foreground="{Binding IsInsightsWeekActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnInsightsWeekClicked"
                        IsEnabled="{Binding InsightsLoading, Converter={StaticResource InvertedBoolConverter}}"/>
                <Button Classes="menu-btn" Content="Range"
                        Margin="0,0,6,0"
                        Background="{Binding IsInsightsRangeActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#33aaff,#4a4a4a'}"
                        Foreground="{Binding IsInsightsRangeActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnPickRangeClicked"
                        IsEnabled="{Binding InsightsLoading, Converter={StaticResource InvertedBoolConverter}}"/>
            </WrapPanel>
        </Border>
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
        <!-- Main Content Area -->
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Calls list -->
            <ScrollViewer Grid.Row="1"
                          Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          IsVisible="{Binding IsCallsMode}">
                <Border Padding="10">
                    <StackPanel Spacing="8">
                        <!-- Recent Calls List -->
                        <ItemsControl ItemsSource="{Binding GroupedCalls}"
                                      ItemTemplate="{StaticResource CallGroupTemplateSelector}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Styles>
                                <Style Selector="ContentPresenter">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </ItemsControl.Styles>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Insights list -->
            <Grid Grid.Row="1"
                  Grid.Column="0"
                  IsVisible="{Binding IsInsightsMode}">
                <!-- Content area: 20% narrative (left), 80% tiles (right) -->
                <Grid Margin="10"
                      ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding InsightsNarrativePaneWidth, Mode=TwoWay}"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="{Binding InsightsTilesPaneWidth, Mode=TwoWay}"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="#1f2f3d"
                            BorderBrush="#36566f"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8,6"
                            IsVisible="{Binding IsInsightsNarrativePaneVisible}">
                        <Grid RowDefinitions="Auto,*">
                            <Button Grid.Row="0"
                                    Content="{Binding InsightsSummaryPaneArrow}"
                                    Width="44"
                                    Height="40"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Padding="8,4"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Classes="menu-btn"
                                    Click="OnInsightsSummaryPaneArrowClicked"/>
                            <ScrollViewer Grid.Row="1"
                                          Margin="0,6,0,0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding InsightsNarrativeSections}">
                                    <ItemsControl.Styles>
                                        <Style Selector="ContentPresenter">
                                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ItemsControl.Styles>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:InsightsNarrativeSection">
                                            <Grid RowDefinitions="Auto,2"
                                                  Margin="0,0,0,10">
                                                <StackPanel Grid.Row="0"
                                                            Spacing="4"
                                                            Margin="0,0,0,8">
                                                    <SelectableTextBlock Text="{Binding Title}"
                                                                         Foreground="#d7ecff"
                                                                         FontWeight="SemiBold"
                                                                         HorizontalAlignment="Center"
                                                                         TextAlignment="Center"
                                                                         FontSize="{DynamicResource CurrentFontSize}"/>
                                                    <ItemsControl ItemsSource="{Binding Bullets}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="local:InsightsNarrativeBullet">
                                                                <TextBlock Text="{Binding DisplayText}"
                                                                           Foreground="#c7dff5"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,0,0,2"
                                                                           FontSize="{DynamicResource CurrentFontSize}"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                                <Rectangle Grid.Row="1"
                                                           Fill="#7aaad6"
                                                           Height="2"
                                                           HorizontalAlignment="Stretch"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <GridSplitter Grid.Column="1"
                                  Width="6"
                                  Background="#36566f"
                                  ResizeDirection="Columns"
                                  ShowsPreview="True"
                                  IsVisible="{Binding IsInsightsNarrativePaneVisible}"/>

                    <Grid Grid.Column="2" RowDefinitions="Auto,*" RowSpacing="8">
                        <WrapPanel Grid.Row="0" Orientation="Horizontal">
                            <Button Classes="menu-btn"
                                    Content="{Binding InsightsSummaryVisibilityButtonText}"
                                    Margin="0,0,8,0"
                                    Click="OnInsightsSummaryVisibilityClicked"/>
                            <Border Width="1"
                                    Height="26"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Background="#5f86a8"/>
                            <Button Classes="menu-btn" Content="All"
                                    Margin="0,0,6,0"
                                    Background="{Binding IsInsightsCategoryAllActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#33aaff,#4a4a4a'}"
                                    Foreground="{Binding IsInsightsCategoryAllActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                                    Click="OnInsightsCategoryAllClicked"/>
                            <Button Classes="menu-btn" Content="Police"
                                    Margin="0,0,6,0"
                                    Background="{Binding IsInsightsCategoryPoliceActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#33aaff,#4a4a4a'}"
                                    Foreground="{Binding IsInsightsCategoryPoliceActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                                    Click="OnInsightsCategoryPoliceClicked"/>
                            <Button Classes="menu-btn" Content="Fire"
                                    Margin="0,0,6,0"
                                    Background="{Binding IsInsightsCategoryFireActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#33aaff,#4a4a4a'}"
                                    Foreground="{Binding IsInsightsCategoryFireActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                                    Click="OnInsightsCategoryFireClicked"/>
                            <Button Classes="menu-btn" Content="EMS"
                                    Margin="0,0,6,0"
                                    Background="{Binding IsInsightsCategoryEmsActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#33aaff,#4a4a4a'}"
                                    Foreground="{Binding IsInsightsCategoryEmsActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                                    Click="OnInsightsCategoryEmsClicked"/>
                            <Button Classes="menu-btn" Content="Traffic"
                                    Margin="0,0,6,0"
                                    Background="{Binding IsInsightsCategoryTrafficActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#33aaff,#4a4a4a'}"
                                    Foreground="{Binding IsInsightsCategoryTrafficActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                                    Click="OnInsightsCategoryTrafficClicked"/>
                            <Button Classes="menu-btn" Content="Utilities"
                                    Margin="0,0,6,0"
                                    Background="{Binding IsInsightsCategoryUtilitiesActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#33aaff,#4a4a4a'}"
                                    Foreground="{Binding IsInsightsCategoryUtilitiesActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                                    Click="OnInsightsCategoryUtilitiesClicked"/>
                            <Button Classes="menu-btn" Content="Other"
                                    Margin="0,0,6,0"
                                    Background="{Binding IsInsightsCategoryOtherActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#33aaff,#4a4a4a'}"
                                    Foreground="{Binding IsInsightsCategoryOtherActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                                    Click="OnInsightsCategoryOtherClicked"/>
                        </WrapPanel>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding InsightsCategorySections}"
                                          ItemTemplate="{StaticResource InsightCategoryTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
                
                <!-- Loading overlay -->
                <Border Background="#000000aa"
                        IsVisible="{Binding InsightsLoading}"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="15">
                        <ProgressBar Width="200" Height="4" Value="0" IsIndeterminate="True"/>
                        <TextBlock Text="{Binding InsightsStatusText}"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Footer Status (bottom) -->
        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#222"
                Padding="8"
                BorderBrush="#444"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="560" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- Left side: Stats -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="15">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="Calls:" Foreground="White" />
                        <TextBlock Text="{Binding VisibleCallCount}" Foreground="#00d2ff" FontWeight="Bold" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="Alerts:" Foreground="White" />
                        <TextBlock Text="{Binding VisibleAlertCount}" Foreground="#ffaa00" FontWeight="Bold" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="{Binding UsageText}" Foreground="White" />
                    </StackPanel>
                </StackPanel>
                <!-- Status text channels: radio (green), insights (blue), system (white) -->
                <StackPanel Grid.Column="1" Margin="15,0,0,0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                    <TextBlock Text="{Binding RadioStatusText}"
                               Foreground="#00ff7f"
                               FontWeight="SemiBold"
                               MaxWidth="180"
                               TextTrimming="CharacterEllipsis"
                               TextAlignment="Left" />
                    <TextBlock Text="{Binding InsightsStatusLineText}"
                               Foreground="#7cc6ff"
                               FontWeight="SemiBold"
                               MaxWidth="220"
                               TextTrimming="CharacterEllipsis"
                               TextAlignment="Left" />
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#ffffff"
                               MaxWidth="220"
                               TextTrimming="CharacterEllipsis"
                               TextAlignment="Left" />
                </StackPanel>
                <!-- Spacer -->
                <Grid Grid.Column="2" />
                <!-- Radio data source indicator -->
                <TextBlock Grid.Column="3"
                           Text="{Binding RadioDataSourceText}"
                           Foreground="#8dbfff"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="10,0,8,0"
                           IsVisible="{Binding IsCallsMode}"/>
                <!-- Mode indicator -->
                <Border Grid.Column="4"
                        Background="{Binding ModeIndicatorColor}"
                        CornerRadius="4"
                        Padding="8,2"
                        VerticalAlignment="Center"
                        Margin="15,0,5,0">
                    <TextBlock Text="{Binding ModeIndicatorText}"
                               Foreground="Black"
                               FontWeight="Bold"
                               FontSize="11" />
                </Border>
                <!-- Bell icon -->
                <Path Grid.Column="5"
                      Data="M12 22A2 2 0 0 0 14 20H10A2 2 0 0 0 12 22M18 16V11A6 6 0 0 0 13 5.03V5A1 1 0 0 0 11 5V5.03A6 6 0 0 0 6 11V16L4 18V19H20V18L18 16Z"
                      Fill="{Binding BellColor}"
                      Width="18"
                      Height="18"
                      Margin="5,-5,5,0"
					  VerticalAlignment="Center"
                      ToolTip.Tip="{Binding BellToolTipText}"
                      Cursor="Hand"
                      PointerReleased="OnBellClicked"/>
                <!-- Right side: Version -->
                <TextBlock Grid.Column="6"
                           Text="{Binding VersionString}"
                           Foreground="#888"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="5,0,0,0" />
            </Grid>
        </Border>
        
        <!-- Applying settings overlay -->
        <Grid Grid.Row="0"
              Grid.Column="0"
              Grid.RowSpan="2"
              Grid.ColumnSpan="2"
              IsVisible="{Binding IsApplyingSettings}"
              IsHitTestVisible="True"
              Panel.ZIndex="100">
            <Border Background="#80000000"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    IsHitTestVisible="True"/>
            <Border Background="#2a2a2a"
                    BorderBrush="#555"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="True">
                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="Applying settings..."
                               Foreground="White"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Width="220" Height="8"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Right-side pane -->
        <Border Grid.Column="1"
                Grid.Row="0"
                Grid.RowSpan="3"
                Width="415"
                Background="#252525"
                BorderBrush="#444"
                BorderThickness="1,0,0,0"
                IsVisible="{Binding IsPaneOpen}">
            <ContentControl Content="{Binding ActivePaneContent}"/>
        </Border>

        </Grid>
    </DockPanel>
</Window>
