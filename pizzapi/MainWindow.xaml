<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:pizzapi"
        xmlns:models="using:pizzalib"
        xmlns:ToolTip="using:Avalonia.Controls"
        x:Class="pizzapi.MainWindow"
        x:DataType="local:MainWindow"
        x:Name="RootWindow"
        Title="PizzaPi"
        Width="800"
        Height="600"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Icon="/images/logo.png"
        Loaded="OnWindowLoaded">
    <Window.Resources>
        <local:BoolToDoubleConverter x:Key="BoolToDoubleConverter" />
        <local:BoolToStringConverter x:Key="BoolToStringConverter" />
        <local:BoolToColorConverter x:Key="BoolToColorConverter" />
        <local:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        <local:InsightNavigateButtonTextConverter x:Key="InsightNavigateButtonTextConverter" />
        
        <!-- Dynamic button style with active state support -->
        <Style x:Key="TouchButtonStyle" Selector="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        
<!-- Active button style (orange) -->
        <Style x:Key="ActiveButtonStyle" Selector="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Background" Value="#ffaa00"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>


        
        <!-- Inactive button style (gray) -->
        <Style x:Key="InactiveButtonStyle" Selector="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Background" Value="#4a4a4a"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        
        <!-- Data template for group headers -->
        <DataTemplate x:Key="HeaderTemplate" x:DataType="local:CallGroupItem">
            <Button Background="#1a4a1a"
                    Margin="0,4,0,0"
                    Padding="0"
                    Cursor="Hand"
                    Click="OnGroupHeaderClicked"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Center"
                    Classes="header-button">
                <Button.Styles>
                    <Style Selector="Button.header-button">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="#1a4a1a"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                    <Style Selector="Button.header-button:pointerover">
                        <Setter Property="Background" Value="#2a5a2a"/>
                    </Style>
                    <Style Selector="Button.header-button:pressed">
                        <Setter Property="Background" Value="#3a6a3a"/>
                    </Style>
                </Button.Styles>
                <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Top">
                    <!-- Expand/Collapse chevron - use two paths with visibility toggle to prevent shift -->
                    <Grid Width="16" Height="16" VerticalAlignment="Top" Margin="4,-5,10,15">
                        <!-- Collapsed state: chevron pointing right -->
                        <Path Data="M8.59 16.58L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.42z"
                              Fill="#00ff00"
                              Width="16"
                              Height="16"
                              IsVisible="{Binding IsExpanded, Converter={StaticResource InvertedBoolConverter}}"/>
                        <!-- Expanded state: chevron pointing down -->
                        <Path Data="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"
                              Fill="#00ff00"
                              Width="16"
                              Height="16"
                              IsVisible="{Binding IsExpanded}"/>
                    </Grid>
                    <TextBlock Text="{Binding HeaderText}"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#00ff00"
                               VerticalAlignment="Top"/>
                </StackPanel>
            </Button>
        </DataTemplate>
        
		<!-- Data template for call items -->
<DataTemplate x:Key="CallTemplate" x:DataType="local:CallGroupItem">
    <Border Background="{Binding Call.IsCurrentMatch, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#00ff00,Transparent'}"
            BorderBrush="#555"
            BorderThickness="0,0,0,1"
            CornerRadius="0"
            HorizontalAlignment="Stretch"
            Margin="0,0,0,2"
            Padding="2,2">

        <Grid HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="84"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Talkgroup -->
            <TextBlock Grid.Row="0" Grid.ColumnSpan="4"
                       Text="{Binding Call.FriendlyTalkgroup}"
                       FontSize="{DynamicResource CurrentFontSize}"
                       FontWeight="Bold"
                       Foreground="#00d2ff"
                       IsVisible="{Binding ShowTalkgroup}"
					   Padding="4,0,4,2"
                       HorizontalAlignment="Left"/>

            <Button Grid.Row="1"
                    Grid.Column="0"
                    Classes="menu-btn"
                    Height="40"
                    MinWidth="74"
                    Padding="8,4"
                    Click="OnCallPlayClicked">
                <Grid Width="22" Height="22">
                    <Path Data="M8 5.14V19.14L19 12.14L8 5.14Z"
                          Fill="#4CAF50"
                          IsVisible="{Binding Call.IsAudioPlaying, Converter={StaticResource InvertedBoolConverter}}"/>
                    <Path Data="M6 6H18V18H6V6Z"
                          Fill="#f44336"
                          IsVisible="{Binding Call.IsAudioPlaying}"/>
                </Grid>
            </Button>

            <TextBlock Grid.Row="1"
                       Grid.Column="1"
                       Text="{Binding Call.Transcription}"
                       TextTrimming="CharacterEllipsis"
                       MaxLines="1"
                       FontSize="{DynamicResource CurrentFontSize}"
                       Foreground="{Binding Call.IsCurrentMatch, Converter={StaticResource SearchTextForegroundConverter}, FallbackValue=White}"
                       VerticalAlignment="Center"
                       Margin="6,0,10,0"/>

            <TextBlock Grid.Row="1"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       FontSize="12"
                       Foreground="#8ec7ff"
                       Margin="0,0,12,0">
                <TextBlock.Text>
                    <Binding Path="Call.Duration" StringFormat="{}{0}s"/>
                </TextBlock.Text>
            </TextBlock>

            <TextBlock Grid.Row="1"
                       Grid.Column="3"
                       Text="{Binding Call.CallTime}"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="#bbbbbb"
                       Margin="0,0,4,0"/>
        </Grid>
    </Border>
</DataTemplate>

        <DataTemplate x:Key="InsightCategoryTemplate" x:DataType="local:InsightCategorySection">
            <StackPanel Spacing="4" Margin="0,4,0,6">
                <ItemsControl ItemsSource="{Binding VisibleEvents}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:InsightNotableEvent">
                            <StackPanel Spacing="4">
                                <Grid IsVisible="{Binding ShowDateDivider}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Height="1"
                                            Background="#456178"
                                            VerticalAlignment="Center"
                                            Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DateDividerText}"
                                               Foreground="#cfe7ff"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                    <Border Grid.Column="2"
                                            Height="1"
                                            Background="#456178"
                                            VerticalAlignment="Center"
                                            Margin="8,0,0,0"/>
                                </Grid>
                                <Border Background="{Binding CategoryTileBackground}"
                                        BorderBrush="{Binding CategoryAccentColor}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,0,0,8"
                                        Padding="8,6"
                                        HorizontalAlignment="Stretch">
                                    <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                                        <StackPanel Grid.Row="0" Spacing="1">
                                            <SelectableTextBlock Text="{Binding DisplayTitle}"
                                                                 Foreground="{Binding CategoryAccentColor}"
                                                                 FontWeight="SemiBold"
                                                                 FontSize="{DynamicResource InsightsTileFontSize}"
                                                                 TextWrapping="Wrap"/>
                                            <SelectableTextBlock Text="{Binding TimestampDisplay}"
                                                                 Foreground="#9ac7e8"
                                                                 FontSize="{DynamicResource CurrentFontSize}"
                                                                 Margin="0"
                                                                 IsVisible="{Binding TimestampDisplay, Converter={StaticResource StringNotEmptyConverter}}"/>
                                            <SelectableTextBlock Text="{Binding Detail}"
                                                                 Foreground="#dddddd"
                                                                 FontSize="{DynamicResource InsightsTileFontSize}"
                                                                 TextWrapping="Wrap"
                                                                 Margin="0"/>
                                        </StackPanel>
                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                                <Button Content="Transcript"
                                                        Classes="menu-btn"
                                                        Padding="8,4"
                                                        FontSize="12"
                                                        MinHeight="30"
                                                        Background="#2f2f2f"
                                                        Foreground="#7dd3fc"
                                                        IsVisible="{Binding CanOpenSources}"
                                                        Click="OnInsightTranscriptClicked"/>
                                                <Button Content="Audio"
                                                        Classes="menu-btn"
                                                        Padding="8,4"
                                                        FontSize="12"
                                                        MinHeight="30"
                                                        Background="#2f2f2f"
                                                        Foreground="#7dd3fc"
                                                        IsVisible="{Binding CanOpenSources}"
                                                        Click="OnInsightAudioClicked"/>
                                                 <Button Classes="menu-btn"
                                                         Padding="8,4"
                                                         FontSize="12"
                                                         MinHeight="30"
                                                         Background="#2f2f2f"
                                                         Foreground="#7dd3fc"
                                                         IsVisible="{Binding CanOpenSources}"
                                                         Click="OnInsightNextCallClicked">
                                                     <Button.Content>
                                                         <Binding Path="MatchedCallCount" Converter="{StaticResource InsightNavigateButtonTextConverter}"/>
                                                     </Button.Content>
                                                 </Button>
                                            </StackPanel>
                                            <Border Grid.Column="1" Margin="8,0,0,0" Width="30" Height="30" CornerRadius="15">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding Confidence, Converter={StaticResource ConfidenceColorConverter}}"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding ConfidencePercent}"
                                                       Foreground="#111111"
                                                       FontSize="9"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Classes="menu-btn"
                        Content="{Binding HiddenCount, StringFormat=Show more (+{0})}"
                        Padding="10,8"
                        MinHeight="40"
                        HorizontalAlignment="Left"
                        Margin="4,2,0,0"
                        Background="#303846"
                        Foreground="#b9d9ff"
                        IsVisible="{Binding HasHiddenEvents}"
                        Click="OnInsightShowMoreClicked"/>
                <Button Classes="menu-btn"
                        Content="Show fewer"
                        Padding="10,8"
                        MinHeight="40"
                        HorizontalAlignment="Left"
                        Margin="4,2,0,0"
                        Background="#303846"
                        Foreground="#b9d9ff"
                        IsVisible="{Binding CanShowFewer}"
                        Click="OnInsightShowFewerClicked"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="InsightWindowSummaryTemplate" x:DataType="local:InsightSummaryWindow">
            <Border Background="#1f2f3d"
                    BorderBrush="#36566f"
                    BorderThickness="1"
                    CornerRadius="6"
                    Margin="0,0,0,10"
                    Padding="10">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding FriendlyWindowLabel}"
                               Foreground="#d7ecff"
                               FontWeight="SemiBold"
                               FontSize="{DynamicResource CurrentFontSize}"/>
                    <TextBlock Text="{Binding WindowStart, StringFormat='{}{0:MMM d, h:mm tt}'}"
                               Foreground="#9ac7e8"
                               FontSize="{DynamicResource CurrentFontSize}"/>
                    <TextBlock Text="{Binding WindowEnd, StringFormat='{}to {0:MMM d, h:mm tt}'}"
                               Foreground="#9ac7e8"
                               FontSize="{DynamicResource CurrentFontSize}"/>
                    <SelectableTextBlock Text="{Binding SummaryText}"
                                         Foreground="#e4e4e4"
                                         TextWrapping="Wrap"
                                         FontSize="{DynamicResource InsightsTileFontSize}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

		        
<!-- Data template selector -->
        <local:CallGroupItemTemplateSelector x:Key="CallGroupTemplateSelector"
                                              HeaderTemplate="{StaticResource HeaderTemplate}"
                                              CallTemplate="{StaticResource CallTemplate}" />
        
        <!-- Search bar visibility converter -->
        <local:IntGreaterThanZeroConverter x:Key="IntGreaterThanZeroConverter"/>
        <local:SearchHighlightConverter x:Key="SearchHighlightConverter"/>
<local:SearchTextForegroundConverter x:Key="SearchTextForegroundConverter"/>
        <local:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
        <local:AlertSearchBackgroundConverter x:Key="AlertSearchBackgroundConverter"/>
        <local:ButtonActiveStateConverter x:Key="ButtonActiveStateConverter"/>
        <local:StringNotEmptyConverter x:Key="StringNotEmptyConverter"/>
        <local:ConfidenceColorConverter x:Key="ConfidenceColorConverter"/>
    </Window.Resources>

    <Window.Styles>
        <!-- Keep active/inactive menu button colors stable on hover/press -->
        <Style Selector="Button.menu-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"/>
        </Style>
        <Style Selector="Button.menu-btn:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"/>
        </Style>
        <Style Selector="Button.menu-main-btn">
            <Setter Property="MinHeight" Value="68"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#111"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.menu-main-btn:pointerover">
            <Setter Property="BorderBrush" Value="#e6e6e6"/>
        </Style>
        <Style Selector="Button.menu-main-btn:pressed">
            <Setter Property="Padding" Value="16,13,12,11"/>
            <Setter Property="BorderBrush" Value="#0a0a0a"/>
        </Style>
    </Window.Styles>
    
    <DockPanel>
        <!-- Persistent Left Menu -->
        <Border Background="#2f2f2f"
                BorderBrush="#555"
                BorderThickness="0,0,1,0"
                Width="250"
                Padding="10,10,10,8"
                DockPanel.Dock="Left">
            <StackPanel Spacing="8">
                <Border Background="#3a3a3a"
                        BorderBrush="#555"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8"
                        Margin="0,0,0,4">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button Classes="menu-btn" Content="24h"
                                    Height="36"
                                    Padding="8,4"
                                    Background="{Binding IsRange24hActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#00ff00,#4a4a4a'}"
                                    Foreground="{Binding IsRange24hActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                                    Click="OnRange24hClicked"/>
                            <Button Classes="menu-btn" Content="2d"
                                    Height="36"
                                    Padding="8,4"
                                    Background="{Binding IsRange2dActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#00ff00,#4a4a4a'}"
                                    Foreground="{Binding IsRange2dActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                                    Click="OnRange2dClicked"/>
                            <Button Classes="menu-btn" Content="Week"
                                    Height="36"
                                    Padding="8,4"
                                    Background="{Binding IsRangeWeekActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#00ff00,#4a4a4a'}"
                                    Foreground="{Binding IsRangeWeekActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                                    Click="OnRangeWeekClicked"/>
                            <Button Classes="menu-btn" Content="Range"
                                    Height="36"
                                    Padding="8,4"
                                    Background="{Binding IsRangeCustomActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#00ff00,#4a4a4a'}"
                                    Foreground="{Binding IsRangeCustomActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                                    Click="OnPickRangeClicked"/>
                        </StackPanel>
                        <ComboBox Width="190"
                                  HorizontalAlignment="Left"
                                  ItemsSource="{Binding Profiles}"
                                  SelectedItem="{Binding ActiveProfile, Mode=TwoWay}"
                                  SelectionChanged="OnProfileSelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="local:ProcessingProfile">
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Button Classes="menu-btn menu-main-btn"
                        Cursor="Hand"
                        HorizontalAlignment="Stretch"
                        Background="{Binding IsHighlightsSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#33aaff,#4a4a4a'}"
                        Foreground="{Binding IsHighlightsSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        IsEnabled="{Binding IsInsightsEnabled}"
                        Click="OnHighlightsClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Width="24" Height="24"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M7,1.5 C4.7,1.5 2.9,3.3 2.9,5.6 C2.9,7.3 3.8,8.6 5.2,9.6 L5.2,11 L8.8,11 L8.8,9.6 C10.2,8.6 11.1,7.3 11.1,5.6 C11.1,3.3 9.3,1.5 7,1.5 Z M5.4,12.2 L8.6,12.2 L8.6,13.4 L5.4,13.4 Z M5.9,14.4 L8.1,14.4 L8.1,15.2 L5.9,15.2 Z"/>
                        <TextBlock Text="Highlights" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="menu-btn menu-main-btn"
                        Cursor="Hand"
                        HorizontalAlignment="Stretch"
                        Background="{Binding IsAlertsSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#ff9900,#4a4a4a'}"
                        Foreground="{Binding IsAlertsSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnSectionAlertsClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Width="24" Height="24"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M7,1 C4.8,1 3,2.8 3,5 L3,8.5 L1.8,10.2 L1.8,11 L12.2,11 L12.2,10.2 L11,8.5 L11,5 C11,2.8 9.2,1 7,1 Z M5.8,12 C5.8,12.7 6.3,13.2 7,13.2 C7.7,13.2 8.2,12.7 8.2,12 Z"/>
                        <TextBlock Text="Alerts" VerticalAlignment="Center"/>
                        <Border Background="#d62222"
                                CornerRadius="10"
                                MinWidth="20"
                                Height="20"
                                Padding="6,0"
                                IsVisible="{Binding UnreadAlertCount, Converter={StaticResource IntGreaterThanZeroConverter}}">
                            <TextBlock Text="{Binding UnreadAlertCount}"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="12"/>
                        </Border>
                    </StackPanel>
                </Button>

                <Separator Margin="0,2,0,2"/>

                <Button Classes="menu-btn menu-main-btn"
                        Cursor="Hand"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding IsPoliceMenuVisible}"
                        Background="{Binding IsPoliceSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#2b74e4,#4a4a4a'}"
                        Foreground="{Binding IsPoliceSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnSectionPoliceClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Width="24" Height="24"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M7,1.4 L8.6,3.2 L11,3.6 L10.1,5.8 L11.1,8 L8.8,8.4 L7.2,10.2 L5.6,8.4 L3.3,8 L4.3,5.8 L3.4,3.6 L5.8,3.2 Z M7,4.8 L7.5,6.1 L8.9,6.2 L7.8,7 L8.1,8.4 L7,7.6 L5.9,8.4 L6.2,7 L5.1,6.2 L6.5,6.1 Z"/>
                        <TextBlock Text="Police" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="menu-btn menu-main-btn"
                        Cursor="Hand"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding IsFireMenuVisible}"
                        Background="{Binding IsFireSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#cf4b3c,#4a4a4a'}"
                        Foreground="{Binding IsFireSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnSectionFireClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Width="24" Height="24"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M7,1 C9.8,3.5 10.4,6.7 8.8,8.8 C10,8.9 11.2,9.8 11.2,11.2 C11.2,13.2 9.5,15 7.2,15 C4.8,15 3,13.2 3,11 C3,9.4 3.9,8.1 5.3,7.1 C6.7,6 7.3,4.5 7,1 Z"/>
                        <TextBlock Text="Fire" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="menu-btn menu-main-btn"
                        Cursor="Hand"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding IsEmsMenuVisible}"
                        Background="{Binding IsEmsSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#2ea44f,#4a4a4a'}"
                        Foreground="{Binding IsEmsSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnSectionEmsClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Width="24" Height="24"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M6,2 L8,2 L8,5 L11,5 L11,7 L8,7 L8,10 L6,10 L6,7 L3,7 L3,5 L6,5 Z"/>
                        <TextBlock Text="EMS" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="menu-btn menu-main-btn"
                        Cursor="Hand"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding IsTrafficMenuVisible}"
                        Background="{Binding IsTrafficSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#d79a28,#4a4a4a'}"
                        Foreground="{Binding IsTrafficSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnSectionTrafficClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Width="24" Height="24"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M5.5,2 L8.5,2 L8.5,5 L5.5,5 Z M5.5,5.8 L8.5,5.8 L8.5,8.8 L5.5,8.8 Z M5.5,9.6 L8.5,9.6 L8.5,12.6 L5.5,12.6 Z M6.2,2.7 L7.8,2.7 L7.8,4.3 L6.2,4.3 Z M6.2,6.5 L7.8,6.5 L7.8,8.1 L6.2,8.1 Z M6.2,10.3 L7.8,10.3 L7.8,11.9 L6.2,11.9 Z"/>
                        <TextBlock Text="Traffic" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="menu-btn menu-main-btn"
                        Cursor="Hand"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding IsOtherMenuVisible}"
                        Background="{Binding IsOtherSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#8a63d2,#4a4a4a'}"
                        Foreground="{Binding IsOtherSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnSectionOtherClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Width="24" Height="24"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M7,2 C9.5,2 11.4,3.8 11.4,6.1 C11.4,7.7 10.4,8.8 9.2,9.5 C8.6,9.9 8.4,10.2 8.4,10.8 L6.8,10.8 C6.8,9.9 7.1,9.2 7.8,8.7 C8.8,8 9.6,7.4 9.6,6.2 C9.6,5 8.5,4.2 7.1,4.2 C5.8,4.2 4.9,5 4.6,6.1 L3,5.6 C3.5,3.5 5.1,2 7,2 Z M6.8,11.8 L8.4,11.8 L8.4,13.3 L6.8,13.3 Z"/>
                        <TextBlock Text="Other" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Separator Margin="0,2,0,2"/>

                <Button Classes="menu-btn menu-main-btn"
                        Cursor="Hand"
                        HorizontalAlignment="Stretch"
                        Background="{Binding IsSettingsSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#ff9900,#4a4a4a'}"
                        Foreground="{Binding IsSettingsSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnSectionSettingsClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Width="24" Height="24"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M6.9,2 L7.7,2 L8,3.1 C8.4,3.2 8.8,3.3 9.1,3.5 L10.1,2.9 L10.7,3.5 L10.1,4.5 C10.3,4.8 10.4,5.2 10.5,5.6 L11.6,5.9 L11.6,6.7 L10.5,7 C10.4,7.4 10.3,7.8 10.1,8.1 L10.7,9.1 L10.1,9.7 L9.1,9.1 C8.8,9.3 8.4,9.4 8,9.5 L7.7,10.6 L6.9,10.6 L6.6,9.5 C6.2,9.4 5.8,9.3 5.5,9.1 L4.5,9.7 L3.9,9.1 L4.5,8.1 C4.3,7.8 4.2,7.4 4.1,7 L3,6.7 L3,5.9 L4.1,5.6 C4.2,5.2 4.3,4.8 4.5,4.5 L3.9,3.5 L4.5,2.9 L5.5,3.5 C5.8,3.3 6.2,3.2 6.6,3.1 Z M7.3,4.7 C6.4,4.7 5.7,5.4 5.7,6.3 C5.7,7.2 6.4,7.9 7.3,7.9 C8.2,7.9 8.9,7.2 8.9,6.3 C8.9,5.4 8.2,4.7 7.3,4.7 Z"/>
                        <TextBlock Text="Settings" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="menu-btn menu-main-btn"
                        Cursor="Hand"
                        HorizontalAlignment="Stretch"
                        Background="{Binding IsTroubleshootSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#ff5555,#4a4a4a'}"
                        Foreground="{Binding IsTroubleshootSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnSectionTroubleshootClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Width="24" Height="24"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M7,2 L12,11 L2,11 Z M7,5 L7.8,5 L7.8,8 L7,8 Z M7,8.8 L7.8,8.8 L7.8,9.6 L7,9.6 Z"/>
                        <TextBlock Text="{Binding TroubleshootMenuText}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Separator Margin="0,2,0,2"/>

                <Button Classes="menu-btn"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        Width="48"
                        MinWidth="48"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Foreground="White"
                        Padding="0"
                        ToolTip.Tip="{Binding BellToolTipText}"
                        Click="OnBellMenuClicked">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Width="36" Height="36"
                              Fill="Transparent"
                              Stroke="{Binding BellColor}"
                              StrokeThickness="2.2"
                              Stretch="Uniform"
                              Data="M7,2 C5.2,2 3.8,3.4 3.8,5.2 L3.8,8.1 L2.7,9.4 L2.7,10 L11.3,10 L11.3,9.4 L10.2,8.1 L10.2,5.2 C10.2,3.4 8.8,2 7,2 Z M6.1,10.8 C6.1,11.3 6.5,11.7 7,11.7 C7.5,11.7 7.9,11.3 7.9,10.8 Z"/>
                    </Grid>
                </Button>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
        <!-- Main Content Area -->
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Category split view: insights tiles + raw calls -->
            <Grid Grid.Row="1"
                  Grid.Column="0"
                  IsVisible="{Binding IsCallsSectionVisible}"
                  Margin="10"
                  ColumnDefinitions="3*,6,5*">
                <Border Grid.Column="0"
                        Background="#1f2f3d"
                        BorderBrush="#36566f"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8">
                    <Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding InsightsCategorySections}"
                                          ItemTemplate="{StaticResource InsightCategoryTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                        <Border IsVisible="{Binding IsCategoryInsightsEmpty}"
                                Background="#253645"
                                BorderBrush="#36566f"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <StackPanel Spacing="12">
                                <TextBlock Text="No insights summaries available for calls in this category and time range"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="#cfe7ff"
                                           TextWrapping="Wrap"/>
                                <Button Classes="menu-btn"
                                        Content="Generate summaries now"
                                        HorizontalAlignment="Left"
                                        IsVisible="{Binding IsGenerateNowVisible}"
                                        IsEnabled="{Binding CanGenerateNow}"
                                        Click="OnGenerateSummariesNowClicked"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1"
                              Width="6"
                              Background="#36566f"
                              ResizeDirection="Columns"
                              ShowsPreview="True"/>

                <Border Grid.Column="2"
                        Padding="0">
                    <Grid>
                        <DataGrid x:Name="CategoryCallsDataGrid"
                                  ItemsSource="{Binding CategoryGroupedCalls}"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="None"
                                  GridLinesVisibility="None"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  CanUserResizeColumns="False"
                                  CanUserSortColumns="False"
                                  SelectionMode="Single"
                                  RowHeaderWidth="24"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  RowBackground="Transparent"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="local:CallGroupItem">
                                            <ContentControl Content="{Binding}"
                                                            ContentTemplate="{StaticResource CallGroupTemplateSelector}"
                                                            HorizontalAlignment="Stretch"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                            <DataGrid.Styles>
                                <Style Selector="DataGridCell">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                                <Style Selector="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </DataGrid.Styles>
                        </DataGrid>
                        <Border IsVisible="{Binding IsCategoryRawCallsEmpty}"
                                Background="#252525"
                                BorderBrush="#3c3c3c"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <TextBlock Text="No raw calls available for this category"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#dddddd"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Insights list -->
            <Grid Grid.Row="1"
                  Grid.Column="0"
                  IsVisible="{Binding IsInsightsSectionVisible}">
                <Grid Margin="10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding InsightsSummaries}"
                                      ItemTemplate="{StaticResource InsightWindowSummaryTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                    <Border IsVisible="{Binding IsHighlightsEmpty}"
                            Background="#253645"
                            BorderBrush="#36566f"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top">
                        <StackPanel Spacing="12">
                            <TextBlock Text="No highlights available for the given time range"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#cfe7ff"
                                       TextWrapping="Wrap"/>
                            <Button Classes="menu-btn"
                                    Content="Generate highlights now"
                                    HorizontalAlignment="Left"
                                    IsVisible="{Binding IsGenerateNowVisible}"
                                    IsEnabled="{Binding CanGenerateNow}"
                                    Click="OnGenerateHighlightsNowClicked"/>
                        </StackPanel>
                    </Border>
                </Grid>
                
                <!-- Loading overlay -->
                <Border Background="#000000aa"
                        IsVisible="{Binding InsightsLoading}"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="15">
                        <ProgressBar Width="200" Height="4" Value="0" IsIndeterminate="True"/>
                        <TextBlock Text="{Binding InsightsStatusText}"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Alerts history -->
            <Grid Grid.Row="1"
                  Grid.Column="0"
                  IsVisible="{Binding IsAlertsSectionVisible}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Border Padding="10">
                        <ItemsControl ItemsSource="{Binding AlertHistory}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:AlertMatchRecord">
                                    <Border Background="#232323"
                                            BorderBrush="#3c3c3c"
                                            BorderThickness="0,0,0,1"
                                            Padding="6,4">
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
                                            <Button Grid.Column="0"
                                                    Classes="menu-btn"
                                                    Height="40"
                                                    MinWidth="74"
                                                    Padding="8,4"
                                                    Click="OnAlertHistoryPlayClicked">
                                                <Grid Width="22" Height="22">
                                                    <Path Data="M8 5.14V19.14L19 12.14L8 5.14Z"
                                                          Fill="#4CAF50"
                                                          IsVisible="{Binding IsAudioPlaying, Converter={StaticResource InvertedBoolConverter}}"/>
                                                    <Path Data="M6 6H18V18H6V6Z"
                                                          Fill="#f44336"
                                                          IsVisible="{Binding IsAudioPlaying}"/>
                                                </Grid>
                                            </Button>
                                            <TextBlock Grid.Column="1"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center">
                                                <Run Text="{Binding HighlightPrefix}"/>
                                                <Run Text="{Binding HighlightMatch}"
                                                     Foreground="#101010"
                                                     Background="#ffd24d"
                                                     FontWeight="Bold"/>
                                                <Run Text="{Binding HighlightSuffix}"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AlertType}"
                                                       Foreground="#ffaa00"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding DurationSec, StringFormat='{}{0}s'}"
                                                       Foreground="#8ec7ff"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding DisplayTimestamp}"
                                                       Foreground="#bbbbbb"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </ScrollViewer>
                <Border IsVisible="{Binding IsAlertsEmpty}"
                        Margin="10"
                        Background="#3b2f23"
                        BorderBrush="#7a5a3a"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top">
                    <StackPanel Spacing="12">
                        <TextBlock Text="No alerts available for the given time range"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#ffd9b0"
                                   TextWrapping="Wrap"/>
                        <Button Classes="menu-btn"
                                Content="Go to alert configuration"
                                HorizontalAlignment="Left"
                                Click="OnGoToAlertConfigurationClicked"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Settings -->
            <Grid Grid.Row="1"
                  Grid.Column="0"
                  IsVisible="{Binding IsSettingsSectionVisible}">
                <Grid RowDefinitions="Auto,*" Margin="8">
                    <Grid.Styles>
                        <Style Selector="TextBox">
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        </Style>
                        <Style Selector="ComboBox">
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                        </Style>
                    </Grid.Styles>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="LoadButtonProxy" Content="Load" Classes="menu-btn" Click="OnSettingsLoadProxyClicked"/>
                        <Button x:Name="SaveButtonProxy" Content="Save" Classes="menu-btn" Click="OnSettingsSaveProxyClicked"/>
                        <Button x:Name="SaveAsButtonProxy" Content="Save As" Classes="menu-btn" Click="OnSettingsSaveAsProxyClicked"/>
                    </StackPanel>
                    <TabControl x:Name="SettingsTabControl" Grid.Row="1" Margin="0,8,0,0">
                        <TabItem Header="Trunk recorder">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Border Margin="12"
                                        Padding="14"
                                        Width="560"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Background="#232323"
                                        CornerRadius="8"
                                        BorderBrush="#3b3b3b"
                                        BorderThickness="1">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Listen Port" FontWeight="Bold"/>
                                        <TextBlock Text="TCP port where PizzaPi listens for incoming call data from Trunk Recorder."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"
                                                   TextWrapping="Wrap"/>
                                        <TextBox x:Name="SettingsListenPortTextBox"
                                                 Width="180"
                                                 HorizontalAlignment="Left"
                                                 HorizontalContentAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Transcription">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Border Margin="12"
                                        Padding="14"
                                        Width="560"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Background="#232323"
                                        CornerRadius="8"
                                        BorderBrush="#3b3b3b"
                                        BorderThickness="1">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Transcription Model" FontWeight="Bold"/>
                                        <TextBlock Text="Speech model used to convert radio audio into text. Larger models are slower but usually more accurate."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"
                                                   TextWrapping="Wrap"/>
                                        <ComboBox x:Name="SettingsModelComboBox" Width="320">
                                            <ComboBoxItem Content="Default (engine default)" />
                                            <ComboBoxItem Content="whisper-tiny (74MB)" />
                                            <ComboBoxItem Content="whisper-base (142MB)" />
                                            <ComboBoxItem Content="whisper-small (466MB)" />
                                            <ComboBoxItem Content="whisper-medium (1.5GB)" />
                                            <ComboBoxItem Content="whisper-large-v3 (2.9GB)" />
                                            <ComboBoxItem Content="vosk-model-small-en-us-0.15 (50MB)" />
                                            <ComboBoxItem Content="vosk-model-en-us-0.22 (1.8GB)" />
                                            <ComboBoxItem Content="vosk-model-en-us-0.22-lgraph (128MB)" />
                                        </ComboBox>
                                        <TextBlock Text="Transcription Engine" FontWeight="Bold"/>
                                        <TextBlock Text="Inference runtime used by the selected model family (Whisper or Vosk)."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"
                                                   TextWrapping="Wrap"/>
                                        <ComboBox x:Name="SettingsEngineComboBox" Width="220">
                                            <ComboBoxItem Content="Whisper" />
                                            <ComboBoxItem Content="Vosk" />
                                        </ComboBox>
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Alerts">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Grid Margin="12"
                                      ColumnDefinitions="1*,3*"
                                      ColumnSpacing="12"
                                      VerticalAlignment="Top">
                                    <StackPanel Grid.Column="0" Spacing="12" VerticalAlignment="Top">
                                        <Border Padding="14"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Top"
                                                Background="#232323"
                                                CornerRadius="8"
                                                BorderBrush="#3b3b3b"
                                                BorderThickness="1">
                                            <StackPanel Spacing="10">
                                                <TextBlock Text="Email Provider" FontWeight="Bold"/>
                                                <TextBlock Text="Email service used to send test and alert notifications."
                                                           FontSize="11"
                                                           Foreground="#b0b0b0"
                                                           TextWrapping="Wrap"/>
                                                <ComboBox x:Name="SettingsEmailProviderComboBox"
                                                          Width="220"
                                                          HorizontalAlignment="Left">
                                                    <ComboBoxItem Content="Gmail" />
                                                    <ComboBoxItem Content="Yahoo" />
                                                </ComboBox>
                                                <TextBlock Text="Email Address" FontWeight="Bold"/>
                                                <TextBlock Text="Destination account for alerts and optional insights digest."
                                                           FontSize="11"
                                                           Foreground="#b0b0b0"
                                                           TextWrapping="Wrap"/>
                                                <TextBox x:Name="SettingsEmailUserTextBox"
                                                         HorizontalAlignment="Stretch"
                                                         HorizontalContentAlignment="Left"/>
                                                <TextBlock Text="App Password" FontWeight="Bold"/>
                                                <TextBlock Text="Provider-specific app password used for authenticated email sending."
                                                           FontSize="11"
                                                           Foreground="#b0b0b0"
                                                           TextWrapping="Wrap"/>
                                                <TextBox x:Name="SettingsEmailPasswordTextBox"
                                                         HorizontalAlignment="Stretch"
                                                         HorizontalContentAlignment="Left"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Padding="14"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Top"
                                                Background="#232323"
                                                CornerRadius="8"
                                                BorderBrush="#3b3b3b"
                                                BorderThickness="1">
                                            <StackPanel Spacing="10">
                                                <TextBlock Text="Alert Behavior" FontWeight="Bold"/>
                                                <TextBlock Text="Configure playback behavior for alert-matched calls."
                                                           FontSize="11"
                                                           Foreground="#b0b0b0"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="Autoplay Alerts" FontWeight="Bold"/>
                                                <TextBlock Text="Automatically play audio when a call matches an alert."
                                                           FontSize="11"
                                                           Foreground="#b0b0b0"
                                                           TextWrapping="Wrap"/>
                                                <CheckBox x:Name="SettingsAutoplayAlertsCheckBox" Content="Enable autoplay alerts"/>
                                                <TextBlock Text="Snooze Duration" FontWeight="Bold"/>
                                                <TextBlock Text="Default snooze duration used when temporarily muting alert autoplay."
                                                           FontSize="11"
                                                           Foreground="#b0b0b0"
                                                           TextWrapping="Wrap"/>
                                                <ComboBox x:Name="SettingsSnoozeComboBox" Width="140" HorizontalAlignment="Left">
                                                    <ComboBoxItem Content="5 minutes" />
                                                    <ComboBoxItem Content="15 minutes" />
                                                    <ComboBoxItem Content="30 minutes" />
                                                    <ComboBoxItem Content="1 hour" />
                                                </ComboBox>
                                                <TextBlock Text="Test Email" FontWeight="Bold"/>
                                                <TextBlock Text="Send a test message using the current email provider settings."
                                                           FontSize="11"
                                                           Foreground="#b0b0b0"
                                                           TextWrapping="Wrap"/>
                                                <Button Content="Test" Classes="menu-btn" Width="120" HorizontalAlignment="Left" Click="OnSettingsTestEmailClicked"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Padding="10"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top"
                                            Background="#1d1d1d"
                                            CornerRadius="8"
                                            BorderBrush="#3b3b3b"
                                            BorderThickness="1">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="Alert Manager" FontWeight="Bold"/>
                                            <TextBlock Text="Manage rules, matching behavior, and alert scope."
                                                       FontSize="11"
                                                       Foreground="#b0b0b0"
                                                       TextWrapping="Wrap"/>
                                            <ContentControl Content="{Binding AlertsPanelControl}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Talkgroups">
                            <Border Margin="12"
                                    Padding="14"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="#232323"
                                    CornerRadius="8"
                                    BorderBrush="#3b3b3b"
                                    BorderThickness="1">
                                <Grid RowDefinitions="Auto,*"
                                      RowSpacing="10"
                                      IsEnabled="{Binding IsTalkgroupEditorBusy, Converter={StaticResource InvertedBoolConverter}}">
                                        <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="8">
                                            <TextBlock Text="CSV:"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                            <Button Grid.Column="1"
                                                    Content="Import"
                                                    Classes="menu-btn"
                                                    Click="OnSettingsImportTalkgroupsClicked"/>
                                            <Button Grid.Column="2"
                                                    Content="Build"
                                                    Classes="menu-btn"
                                                    Click="OnSettingsBuildTalkgroupsClicked"/>
                                            <Button Grid.Column="3"
                                                    Content="Apply"
                                                    Classes="menu-btn"
                                                    Click="OnTalkgroupApplyClicked"
                                                    IsEnabled="{Binding IsTalkgroupApplyEnabled}"/>
                                            <TextBlock Grid.Column="4"
                                                       Text="|"
                                                       VerticalAlignment="Center"
                                                       Foreground="#8a8a8a"/>
                                            <TextBlock Grid.Column="5"
                                                       Text="Profile:"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                            <ComboBox Grid.Column="6"
                                                      ItemsSource="{Binding TalkgroupEditableProfiles}"
                                                      SelectedItem="{Binding SelectedTalkgroupAddProfile, Mode=TwoWay}"
                                                      MinWidth="180"
                                                      VerticalAlignment="Center"
                                                      IsEnabled="{Binding IsTalkgroupAddProfileEnabled}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate x:DataType="local:ProcessingProfile">
                                                        <TextBlock Text="{Binding Name}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <Button Grid.Column="7"
                                                    Content="Add Selected"
                                                    Classes="menu-btn"
                                                    Click="OnAddSelectedTalkgroupsClicked"
                                                    IsEnabled="{Binding CanAddSelectedTalkgroups}"/>
                                            <TextBlock Grid.Column="8"
                                                       Text="|"
                                                       VerticalAlignment="Center"
                                                       Foreground="#8a8a8a"/>
                                            <TextBlock Grid.Column="9"
                                                       Text="View:"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                            <ComboBox Grid.Column="10"
                                                      ItemsSource="{Binding TalkgroupOpsCategoryFilterOptions}"
                                                      SelectedItem="{Binding SelectedTalkgroupOpsCategoryFilter, Mode=TwoWay}"
                                                      MinWidth="120"
                                                      VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="11"
                                                       Text="Keyword:"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                            <TextBox Grid.Column="12"
                                                     Width="180"
                                                     VerticalAlignment="Center"
                                                     PlaceholderText="Filter talkgroups"
                                                     Text="{Binding TalkgroupKeywordFilter, Mode=TwoWay}"/>
                                            <StackPanel Grid.Column="13" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TalkgroupCoverageText}"
                                                           Foreground="#aaddff"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    <Border Grid.Row="1"
                                            Background="#1a1a1a"
                                            CornerRadius="6"
                                            Padding="6">
                                        <DataGrid x:Name="TalkgroupMappingsDataGrid"
                                                  Grid.Row="0"
                                                  IsEnabled="{Binding IsTalkgroupEditorBusy, Converter={StaticResource InvertedBoolConverter}}"
                                                  IsReadOnly="False"
                                                  ItemsSource="{Binding VisibleTalkgroupMappingRows}"
                                                  SelectionMode="Extended"
                                                  SelectionChanged="OnTalkgroupMappingsGridSelectionChanged"
                                                  VerticalAlignment="Stretch"
                                                  AutoGenerateColumns="False"
                                                  ColumnWidth="SizeToCells"
                                                  CanUserSortColumns="True"
                                                  GridLinesVisibility="Horizontal"
                                                  HeadersVisibility="Column">
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Width="68">
                                                        <DataGridTemplateColumn.Header>
                                                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                                                <CheckBox x:Name="TalkgroupSelectAllCheckBox"
                                                                          IsThreeState="True"
                                                                          VerticalAlignment="Center"
                                                                          HorizontalAlignment="Center"
                                                                          Click="OnTalkgroupSelectAllClicked"/>
                                                                <TextBlock Text="All"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="11"
                                                                           Foreground="#d0d0d0"/>
                                                            </StackPanel>
                                                        </DataGridTemplateColumn.Header>
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate x:DataType="local:TalkgroupMappingRow">
                                                                <CheckBox IsChecked="{Binding IsSelectedForProfile, Mode=TwoWay}"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          PointerPressed="OnTalkgroupSelectionCheckboxPointerPressed"
                                                                          Click="OnTalkgroupSelectionCheckboxClicked"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" SortMemberPath="Id" IsReadOnly="True"/>
                                                    <DataGridTextColumn Header="Mode" Binding="{Binding Mode}" SortMemberPath="Mode" IsReadOnly="True"/>
                                                    <DataGridTextColumn Header="Alpha" Binding="{Binding AlphaTag}" SortMemberPath="AlphaTag" IsReadOnly="True"/>
                                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" SortMemberPath="Description" IsReadOnly="True"/>
                                                    <DataGridTextColumn Header="RR Category" Binding="{Binding Category}" SortMemberPath="Category" IsReadOnly="True"/>
                                                    <DataGridTemplateColumn Header="Ops Category" SortMemberPath="OpsCategory">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate x:DataType="local:TalkgroupMappingRow">
                                                                <ComboBox ItemsSource="{Binding #RootWindow.TalkgroupOpsCategoryOptions}"
                                                                          SelectedItem="{Binding OpsCategory, Mode=TwoWay}"
                                                                          MinWidth="120"
                                                                          HorizontalAlignment="Stretch"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                                    <Border Grid.RowSpan="2"
                                            Background="#101010D8"
                                            IsVisible="{Binding IsTalkgroupEditorBusy}">
                                        <Border HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="#1c1c1c"
                                                BorderBrush="#5f5f5f"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="14,12">
                                            <StackPanel Spacing="10">
                                                <ProgressBar Width="240"
                                                             Height="6"
                                                             IsIndeterminate="True"/>
                                                <TextBlock Text="{Binding TalkgroupAutoResolveStatusText}"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Border>
                                </Grid>
                            </Border>
                        </TabItem>
                        <TabItem Header="Insights">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Grid Margin="12"
                                      ColumnDefinitions="600,16,744"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top">
                                    <Border Grid.Column="0"
                                            Padding="14"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top"
                                            Background="#232323"
                                            CornerRadius="8"
                                            BorderBrush="#3b3b3b"
                                            BorderThickness="1">
                                        <StackPanel Spacing="10">
                                            <CheckBox x:Name="SettingsLmLinkEnabledCheckBox" Content="Enable LM Link insights"/>
                                            <TextBlock Text="Turns on AI summary generation using an OpenAI-compatible LM Link endpoint."
                                                       FontSize="11"
                                                       Foreground="#b0b0b0"
                                                       TextWrapping="Wrap"/>
                                            <CheckBox x:Name="SettingsDailyDigestCheckBox" Content="Enable daily insights digest"/>
                                            <TextBlock Text="Sends a periodic digest email when LM Link and email settings are configured."
                                                       FontSize="11"
                                                       Foreground="#b0b0b0"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="Base URL" FontWeight="Bold"/>
                                            <TextBlock Text="HTTP endpoint root for LM Link."
                                                       FontSize="11"
                                                       Foreground="#b0b0b0"/>
                                            <TextBox x:Name="SettingsLmLinkBaseUrlTextBox" Width="420" HorizontalAlignment="Left"/>
                                            <TextBlock Text="Model" FontWeight="Bold"/>
                                            <TextBlock Text="Model identifier sent with LM Link requests."
                                                       FontSize="11"
                                                       Foreground="#b0b0b0"/>
                                            <TextBox x:Name="SettingsLmLinkModelTextBox" Width="280" HorizontalAlignment="Left"/>
                                            <TextBlock Text="API Key" FontWeight="Bold"/>
                                            <TextBlock Text="Optional token used to authenticate to LM Link."
                                                       FontSize="11"
                                                       Foreground="#b0b0b0"/>
                                            <TextBox x:Name="SettingsLmLinkApiKeyTextBox" Width="280" HorizontalAlignment="Left"/>
                                            <TextBlock Text="Timeout (ms)" FontWeight="Bold"/>
                                            <TextBlock Text="Maximum time to wait for each LM Link request before failing."
                                                       FontSize="11"
                                                       Foreground="#b0b0b0"
                                                       TextWrapping="Wrap"/>
                                            <TextBox x:Name="SettingsLmLinkTimeoutTextBox" Width="100" HorizontalAlignment="Left"/>
                                            <TextBlock Text="Retries" FontWeight="Bold"/>
                                            <TextBlock Text="Number of retry attempts after a failed LM Link request."
                                                       FontSize="11"
                                                       Foreground="#b0b0b0"
                                                       TextWrapping="Wrap"/>
                                            <TextBox x:Name="SettingsLmLinkRetriesTextBox" Width="80" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Padding="14"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top"
                                            Background="#1b2732"
                                            CornerRadius="8"
                                            BorderBrush="#355069"
                                            BorderThickness="1">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="LM Usage Ledger"
                                                       FontWeight="Bold"
                                                       Foreground="#d8ecff"/>
                                            <TextBlock Text="{Binding LmUsageLedgerPath, StringFormat='Ledger: {0}'}"
                                                       FontSize="11"
                                                       Foreground="#9fc1dd"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding LmUsageTierText}"
                                                       FontSize="11"
                                                       Foreground="#9fc1dd"
                                                       TextWrapping="Wrap"/>
                                            <Grid ColumnDefinitions="*,*"
                                                  RowDefinitions="Auto,Auto"
                                                  ColumnSpacing="8"
                                                  RowSpacing="8">
                                                <Border Grid.Row="0" Grid.Column="0" Background="#203445" CornerRadius="6" Padding="8">
                                                    <TextBlock Text="{Binding LmUsage24hText}" Foreground="#d4e8f8" TextWrapping="Wrap"/>
                                                </Border>
                                                <Border Grid.Row="0" Grid.Column="1" Background="#203445" CornerRadius="6" Padding="8">
                                                    <TextBlock Text="{Binding LmUsage2dText}" Foreground="#d4e8f8" TextWrapping="Wrap"/>
                                                </Border>
                                                <Border Grid.Row="1" Grid.Column="0" Background="#203445" CornerRadius="6" Padding="8">
                                                    <TextBlock Text="{Binding LmUsageWeekText}" Foreground="#d4e8f8" TextWrapping="Wrap"/>
                                                </Border>
                                                <Border Grid.Row="1" Grid.Column="1" Background="#203445" CornerRadius="6" Padding="8">
                                                    <TextBlock Text="{Binding LmUsageMonthText}" Foreground="#d4e8f8" TextWrapping="Wrap"/>
                                                </Border>
                                            </Grid>
                                            <Border BorderBrush="#2f465c"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="0"
                                                    Background="#16232f">
                                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                              VerticalScrollBarVisibility="Auto"
                                                              MaxHeight="520">
                                                    <DataGrid ItemsSource="{Binding LmUsageLedgerRows}"
                                                              AutoGenerateColumns="False"
                                                              HeadersVisibility="Column"
                                                              IsReadOnly="True"
                                                              CanUserSortColumns="False"
                                                              CanUserResizeColumns="True"
                                                              GridLinesVisibility="Horizontal"
                                                              MinHeight="220">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="120"/>
                                                            <DataGridTextColumn Header="Trigger" Binding="{Binding Trigger}" Width="160"/>
                                                            <DataGridTextColumn Header="Prompt Tok" Binding="{Binding PromptTokensDisplay}" Width="90"/>
                                                            <DataGridTextColumn Header="Comp Tok" Binding="{Binding CompletionTokensDisplay}" Width="90"/>
                                                            <DataGridTextColumn Header="Total Tok" Binding="{Binding TotalTokensDisplay}" Width="90"/>
                                                            <DataGridTextColumn Header="Std $" Binding="{Binding CostStandardDisplay}" Width="70"/>
                                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="60"/>
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </ScrollViewer>
                                            </Border>
                                            <TextBlock Text="No LM Link usage recorded yet."
                                                       IsVisible="{Binding HasLmUsageLedgerRows, Converter={StaticResource InvertedBoolConverter}}"
                                                       FontSize="12"
                                                       Foreground="#9fc1dd"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Cleanup">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Border Margin="12"
                                        Padding="10"
                                        Width="700"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Background="#1d1d1d"
                                        CornerRadius="8"
                                        BorderBrush="#3b3b3b"
                                        BorderThickness="1">
                                    <ContentControl Content="{Binding CleanupPanelControl}"/>
                                </Border>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="View">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Border Margin="12"
                                        Padding="14"
                                        Width="560"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Background="#232323"
                                        CornerRadius="8"
                                        BorderBrush="#3b3b3b"
                                        BorderThickness="1">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Text Size" FontWeight="Bold"/>
                                        <TextBlock Text="Adjust global UI font size for better readability."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Content="A-" Classes="menu-btn" Click="OnDecreaseFontSizeClicked"/>
                                            <Button Content="A+" Classes="menu-btn" Click="OnIncreaseFontSizeClicked"/>
                                        </StackPanel>

                                        <TextBlock Text="Preview"
                                                   FontWeight="Bold"
                                                   Margin="0,8,0,0"/>
                                        <TextBlock Text="Sample call card updates live as you change text size."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"
                                                   TextWrapping="Wrap"/>
                                        <Border Background="#1f2f3d"
                                                BorderBrush="#36566f"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10"
                                                Margin="0,2,0,0">
                                            <StackPanel Spacing="6">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Border Background="#8a63d2"
                                                            CornerRadius="4"
                                                            Padding="4,1">
                                                        <TextBlock Text="OTHER"
                                                                   FontSize="{DynamicResource CurrentFontSize}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#000000"/>
                                                    </Border>
                                                    <TextBlock Text="11:42 PM"
                                                               FontSize="{DynamicResource CurrentFontSize}"
                                                               Foreground="#cfe7ff"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="Mahan Gap Response"
                                                           FontSize="{DynamicResource CurrentFontSize}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#ffffff"/>
                                                <TextBlock Text="Unit advised possible road hazard near Harrison Pike. Monitoring for additional traffic-related updates."
                                                           FontSize="{DynamicResource CurrentFontSize}"
                                                           Foreground="#d4d4d4"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Profiles">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Border Margin="12"
                                        Padding="14"
                                        Width="560"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Background="#232323"
                                        CornerRadius="8"
                                        BorderBrush="#3b3b3b"
                                        BorderThickness="1">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Active Profile" FontWeight="Bold"/>
                                        <TextBlock Text="Profile controls which categories and talkgroups are visible and processed."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"
                                                   TextWrapping="Wrap"/>
                                        <ComboBox Width="260"
                                                  ItemsSource="{Binding Profiles}"
                                                  SelectedItem="{Binding ProfileEditorSelectedProfile, Mode=TwoWay}"
                                                  SelectionChanged="OnProfileEditorSelectionChanged">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="local:ProcessingProfile">
                                                    <TextBlock Text="{Binding Name}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBlock Text="Create Profile" FontWeight="Bold"/>
                                        <TextBlock Text="Create named profile presets for different monitoring scenarios."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"
                                                   TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBox x:Name="ProfileNameTextBox" Width="180" PlaceholderText="New profile name"/>
                                            <Button Content="Create" Classes="menu-btn" Click="OnCreateProfileClicked"/>
                                        </StackPanel>
                                        <TextBlock Text="Included Categories" FontWeight="Bold"/>
                                        <TextBlock Text="Choose which category menus and filters are enabled for this profile."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"
                                                   TextWrapping="Wrap"/>
                                        <WrapPanel ItemWidth="120">
                                            <CheckBox x:Name="ProfileIncludePoliceCheckBox" Content="Police" IsChecked="True"/>
                                            <CheckBox x:Name="ProfileIncludeFireCheckBox" Content="Fire" IsChecked="True"/>
                                            <CheckBox x:Name="ProfileIncludeEmsCheckBox" Content="EMS" IsChecked="True"/>
                                            <CheckBox x:Name="ProfileIncludeTrafficCheckBox" Content="Traffic" IsChecked="True"/>
                                            <CheckBox x:Name="ProfileIncludeOtherCheckBox" Content="Other" IsChecked="True"/>
                                        </WrapPanel>
                                        <TextBlock Text="Allowed Talkgroups" FontWeight="Bold"/>
                                        <TextBlock Text="Comma-separated talkgroup IDs. Leave blank to allow all talkgroups."
                                                   FontSize="11"
                                                   Foreground="#b0b0b0"
                                                   TextWrapping="Wrap"/>
                                        <TextBox x:Name="ProfileTalkgroupsTextBox" Width="420"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Content="Update"
                                                    Classes="menu-btn"
                                                    Width="140"
                                                    Click="OnUpdateProfileClicked"
                                                    IsEnabled="{Binding HasProfileEditorSelection}"/>
                                            <Button Content="Delete"
                                                    Classes="menu-btn"
                                                    Width="140"
                                                    Click="OnDeleteProfileClicked"
                                                    IsEnabled="{Binding CanDeleteSelectedProfile}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Grid>

            <!-- Troubleshoot -->
            <Grid Grid.Row="1"
                  Grid.Column="0"
                  IsVisible="{Binding IsTroubleshootSectionVisible}">
                <TabControl Margin="8">
                    <TabItem Header="Pizzapi">
                        <Grid RowDefinitions="Auto,*" Margin="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Copy" Classes="menu-btn" Click="OnCopyTroubleshootLogClicked"/>
                                <TextBlock Text="Trace level:" VerticalAlignment="Center" Foreground="#d0d0d0"/>
                                <ComboBox Width="180"
                                          ItemsSource="{Binding TroubleshootTraceLevelOptions}"
                                          SelectedItem="{Binding SelectedTroubleshootTraceLevel, Mode=TwoWay}"/>
                                <TextBlock Text="Pizzapi log:" VerticalAlignment="Center" Foreground="#d0d0d0"/>
                                <ComboBox Width="360"
                                          ItemsSource="{Binding PizzaPiLogOptions}"
                                          SelectedItem="{Binding SelectedPizzaPiLogOption, Mode=TwoWay}"/>
                            </StackPanel>
                            <TextBox Grid.Row="1"
                                     Margin="0,8,0,0"
                                     Text="{Binding PizzaPiLogText}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"/>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Trunk Recorder" IsEnabled="{Binding IsTrunkTroubleshootVisible}">
                        <Grid RowDefinitions="Auto,*" Margin="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Restart" Classes="menu-btn" Click="OnRestartTrunkRecorderClicked"/>
                                <Button Content="Copy" Classes="menu-btn" Click="OnCopyTroubleshootLogClicked"/>
                            </StackPanel>
                            <TextBox Grid.Row="1"
                                     Margin="0,8,0,0"
                                     Text="{Binding TrunkRecorderLogText}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <!-- Footer Status (bottom) -->
        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#222"
                Padding="8"
                BorderBrush="#444"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="0"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding FooterProfileText}" Foreground="#7dd3fc" FontSize="12"/>
                    <TextBlock Text="  |  " Foreground="#666666" FontSize="12"/>
                    <TextBlock Text="{Binding FooterCallsText}" Foreground="#ffffff" FontSize="12"/>
                    <TextBlock Text="  " Foreground="#666666" FontSize="12"/>
                    <TextBlock Text="{Binding FooterAlertsText}" Foreground="#ffb366" FontSize="12"/>
                    <TextBlock Text="  " Foreground="#666666" FontSize="12"/>
                    <TextBlock Text="{Binding FooterTokensText}" Foreground="#9ad67d" FontSize="12"/>
                    <TextBlock Text="  |  " Foreground="#666666" FontSize="12"/>
                    <TextBlock Text="{Binding FooterStatusText}"
                               Foreground="#d7d7d7"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               Width="420"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding VersionString}"
                           Foreground="#888"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="5,0,0,0" />
            </Grid>
        </Border>
        
        <!-- Applying settings overlay -->
        <Grid Grid.Row="0"
              Grid.Column="0"
              Grid.RowSpan="2"
              Grid.ColumnSpan="1"
              IsVisible="{Binding IsApplyingSettings}"
              IsHitTestVisible="True"
              Panel.ZIndex="100">
            <Border Background="#80000000"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    IsHitTestVisible="True"/>
            <Border Background="#2a2a2a"
                    BorderBrush="#555"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="True">
                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="Applying settings..."
                               Foreground="White"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Width="220" Height="8"/>
                </StackPanel>
            </Border>
        </Grid>

        </Grid>
    </DockPanel>
</Window>

