<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:pizzapi"
        xmlns:models="using:pizzalib"
        xmlns:ToolTip="using:Avalonia.Controls"
        x:Class="pizzapi.MainWindow"
        x:DataType="local:MainWindow"
        x:Name="RootWindow"
        Title="PizzaPi"
        Width="800"
        Height="600"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Icon="/images/logo.png"
        Loaded="OnWindowLoaded">
    <Window.Resources>
        <local:BoolToDoubleConverter x:Key="BoolToDoubleConverter" />
        <local:BoolToStringConverter x:Key="BoolToStringConverter" />
        <local:BoolToColorConverter x:Key="BoolToColorConverter" />
        <local:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        <local:StringHasTextConverter x:Key="StringHasTextConverter" />
        <local:InsightNavigateButtonTextConverter x:Key="InsightNavigateButtonTextConverter" />
        
        <!-- Dynamic button style with active state support -->
        <Style x:Key="TouchButtonStyle" Selector="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        
<!-- Active button style (orange) -->
        <Style x:Key="ActiveButtonStyle" Selector="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Background" Value="#ffaa00"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>


        
        <!-- Inactive button style (gray) -->
        <Style x:Key="InactiveButtonStyle" Selector="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Background" Value="#4a4a4a"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        
        <!-- Data template for group headers -->
        <DataTemplate x:Key="HeaderTemplate" x:DataType="local:CallGroupItem">
            <Button Background="#1a4a1a"
                    Margin="0,4,0,0"
                    Padding="0"
                    Cursor="Hand"
                    Click="OnGroupHeaderClicked"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Center"
                    Classes="header-button call-pulse-target"
                    Classes.pulse="{Binding IsPulseTarget}">
                <Button.Styles>
                    <Style Selector="Button.header-button">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="#1a4a1a"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                    <Style Selector="Button.header-button:pointerover">
                        <Setter Property="Background" Value="#2a5a2a"/>
                    </Style>
                    <Style Selector="Button.header-button:pressed">
                        <Setter Property="Background" Value="#3a6a3a"/>
                    </Style>
                </Button.Styles>
                <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Top">
                    <!-- Expand/Collapse chevron - use two paths with visibility toggle to prevent shift -->
                    <Grid Width="16" Height="16" VerticalAlignment="Top" Margin="4,-5,10,15">
                        <!-- Collapsed state: chevron pointing right -->
                        <Path Data="M8.59 16.58L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.42z"
                              Fill="#00ff00"
                              Width="16"
                              Height="16"
                              IsVisible="{Binding IsExpanded, Converter={StaticResource InvertedBoolConverter}}"/>
                        <!-- Expanded state: chevron pointing down -->
                        <Path Data="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"
                              Fill="#00ff00"
                              Width="16"
                              Height="16"
                              IsVisible="{Binding IsExpanded}"/>
                    </Grid>
                    <TextBlock Text="{Binding HeaderText}"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#00ff00"
                               VerticalAlignment="Top"/>
                </StackPanel>
            </Button>
        </DataTemplate>
        
		<!-- Data template for call items -->
<DataTemplate x:Key="CallTemplate" x:DataType="local:CallGroupItem">
    <Border Background="{Binding Call.IsCurrentMatch, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#00ff00,Transparent'}"
            BorderBrush="#555"
            BorderThickness="0,0,0,1"
            CornerRadius="0"
            HorizontalAlignment="Stretch"
            Margin="0,0,0,2"
            Padding="2,2">

        <Grid HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="84"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Talkgroup -->
            <TextBlock Grid.Row="0" Grid.ColumnSpan="4"
                       Text="{Binding Call.FriendlyTalkgroup}"
                       FontSize="{DynamicResource CurrentFontSize}"
                       FontWeight="Bold"
                       Foreground="#00d2ff"
                       IsVisible="{Binding ShowTalkgroup}"
					   Padding="4,0,4,2"
                       HorizontalAlignment="Left"/>

            <Button Grid.Row="1"
                    Grid.Column="0"
                    Classes="menu-btn"
                    Height="40"
                    MinWidth="74"
                    Padding="8,4"
                    Click="OnCallPlayClicked">
                <Grid Width="22" Height="22">
                    <Path Data="M8 5.14V19.14L19 12.14L8 5.14Z"
                          Fill="#4CAF50"
                          IsVisible="{Binding Call.IsAudioPlaying, Converter={StaticResource InvertedBoolConverter}}"/>
                    <Path Data="M6 6H18V18H6V6Z"
                          Fill="#f44336"
                          IsVisible="{Binding Call.IsAudioPlaying}"/>
                </Grid>
            </Button>

            <TextBlock Grid.Row="1"
                       Grid.Column="1"
                       Text="{Binding Call.Transcription}"
                       TextTrimming="CharacterEllipsis"
                       MaxLines="1"
                       FontSize="{DynamicResource CurrentFontSize}"
                       Foreground="{Binding Call.IsCurrentMatch, Converter={StaticResource SearchTextForegroundConverter}, FallbackValue=White}"
                       VerticalAlignment="Center"
                       Margin="6,0,10,0"/>

            <TextBlock Grid.Row="1"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       FontSize="12"
                       Foreground="#8ec7ff"
                       Margin="0,0,12,0">
                <TextBlock.Text>
                    <Binding Path="Call.Duration" StringFormat="{}{0}s"/>
                </TextBlock.Text>
            </TextBlock>

            <TextBlock Grid.Row="1"
                       Grid.Column="3"
                       Text="{Binding Call.CallTime}"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="#bbbbbb"
                       Margin="0,0,4,0"/>
        </Grid>
    </Border>
</DataTemplate>

        <DataTemplate x:Key="InsightCategoryTemplate" x:DataType="local:InsightCategorySection">
            <StackPanel Spacing="4" Margin="0,4,0,6">
                <ItemsControl ItemsSource="{Binding VisibleEvents}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:InsightNotableEvent">
                            <StackPanel Spacing="4">
                                <Grid IsVisible="{Binding ShowDateDivider}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Height="1"
                                            Background="#456178"
                                            VerticalAlignment="Center"
                                            Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DateDividerText}"
                                               Foreground="#cfe7ff"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                    <Border Grid.Column="2"
                                            Height="1"
                                            Background="#456178"
                                            VerticalAlignment="Center"
                                            Margin="8,0,0,0"/>
                                </Grid>
                                <Border Background="{Binding CategoryTileBackground}"
                                        BorderBrush="{Binding CategoryAccentColor}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,0,0,8"
                                        Padding="8,6"
                                        HorizontalAlignment="Stretch">
                                    <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                                        <StackPanel Grid.Row="0" Spacing="1">
                                            <SelectableTextBlock Text="{Binding DisplayTitle}"
                                                                 Foreground="{Binding CategoryAccentColor}"
                                                                 FontWeight="SemiBold"
                                                                 FontSize="{DynamicResource InsightsTileFontSize}"
                                                                 TextWrapping="Wrap"/>
                                            <SelectableTextBlock Text="{Binding TimestampDisplay}"
                                                                 Foreground="#9ac7e8"
                                                                 FontSize="{DynamicResource CurrentFontSize}"
                                                                 Margin="0"
                                                                 IsVisible="{Binding TimestampDisplay, Converter={StaticResource StringNotEmptyConverter}}"/>
                                            <SelectableTextBlock Text="{Binding Detail}"
                                                                 Foreground="#dddddd"
                                                                 FontSize="{DynamicResource InsightsTileFontSize}"
                                                                 TextWrapping="Wrap"
                                                                 Margin="0"/>
                                        </StackPanel>
                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                                <Button Content="Transcript"
                                                        Classes="menu-btn"
                                                        Padding="8,4"
                                                        FontSize="12"
                                                        MinHeight="30"
                                                        Background="#2f2f2f"
                                                        Foreground="#7dd3fc"
                                                        IsVisible="{Binding CanOpenSources}"
                                                        Click="OnInsightTranscriptClicked"/>
                                                <Button Content="Audio"
                                                        Classes="menu-btn"
                                                        Padding="8,4"
                                                        FontSize="12"
                                                        MinHeight="30"
                                                        Background="#2f2f2f"
                                                        Foreground="#7dd3fc"
                                                        IsVisible="{Binding CanOpenSources}"
                                                        Click="OnInsightAudioClicked"/>
                                                 <Button Classes="menu-btn"
                                                         Padding="8,4"
                                                         FontSize="12"
                                                         MinHeight="30"
                                                         Background="#2f2f2f"
                                                         Foreground="#7dd3fc"
                                                         IsVisible="{Binding CanOpenSources}"
                                                         Click="OnInsightNextCallClicked">
                                                     <Button.Content>
                                                         <Binding Path="MatchedCallCount" Converter="{StaticResource InsightNavigateButtonTextConverter}"/>
                                                     </Button.Content>
                                                 </Button>
                                            </StackPanel>
                                            <Border Grid.Column="1" Margin="8,0,0,0" Width="30" Height="30" CornerRadius="15">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding Confidence, Converter={StaticResource ConfidenceColorConverter}}"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding ConfidencePercent}"
                                                       Foreground="#111111"
                                                       FontSize="9"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Classes="menu-btn"
                        Content="{Binding HiddenCount, StringFormat=Show more (+{0})}"
                        Padding="10,8"
                        MinHeight="40"
                        HorizontalAlignment="Left"
                        Margin="4,2,0,0"
                        Background="#303846"
                        Foreground="#b9d9ff"
                        IsVisible="{Binding HasHiddenEvents}"
                        Click="OnInsightShowMoreClicked"/>
                <Button Classes="menu-btn"
                        Content="Show fewer"
                        Padding="10,8"
                        MinHeight="40"
                        HorizontalAlignment="Left"
                        Margin="4,2,0,0"
                        Background="#303846"
                        Foreground="#b9d9ff"
                        IsVisible="{Binding CanShowFewer}"
                        Click="OnInsightShowFewerClicked"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="InsightWindowSummaryTemplate" x:DataType="local:InsightSummaryWindow">
            <Border Background="#1f2f3d"
                    BorderBrush="#36566f"
                    BorderThickness="1"
                    CornerRadius="6"
                    Margin="0,0,8,10"
                    Padding="10">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding FriendlyWindowLabel}"
                               Foreground="#d7ecff"
                               FontWeight="SemiBold"
                               FontSize="{DynamicResource CurrentFontSize}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding WindowStart, StringFormat='{}{0:MMM d, h:mm tt}'}"
                               Foreground="#9ac7e8"
                               FontSize="{DynamicResource CurrentFontSize}"/>
                    <TextBlock Text="{Binding WindowEnd, StringFormat='{}to {0:MMM d, h:mm tt}'}"
                               Foreground="#9ac7e8"
                               FontSize="{DynamicResource CurrentFontSize}"/>
                    <SelectableTextBlock Text="{Binding SummaryText}"
                                         Foreground="#e4e4e4"
                                         TextWrapping="Wrap"
                                         FontSize="{DynamicResource InsightsTileFontSize}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

		        
<!-- Data template selector -->
        <local:CallGroupItemTemplateSelector x:Key="CallGroupTemplateSelector"
                                              HeaderTemplate="{StaticResource HeaderTemplate}"
                                              CallTemplate="{StaticResource CallTemplate}" />
        
        <!-- Search bar visibility converter -->
        <local:IntGreaterThanZeroConverter x:Key="IntGreaterThanZeroConverter"/>
        <local:SearchHighlightConverter x:Key="SearchHighlightConverter"/>
<local:SearchTextForegroundConverter x:Key="SearchTextForegroundConverter"/>
        <local:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
        <local:AlertSearchBackgroundConverter x:Key="AlertSearchBackgroundConverter"/>
        <local:ButtonActiveStateConverter x:Key="ButtonActiveStateConverter"/>
        <local:StringNotEmptyConverter x:Key="StringNotEmptyConverter"/>
        <local:ConfidenceColorConverter x:Key="ConfidenceColorConverter"/>
    </Window.Resources>

    <Window.Styles>
        <!-- Keep active/inactive menu button colors stable on hover/press -->
        <Style Selector="Button.menu-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"/>
        </Style>
        <Style Selector="Button.menu-btn:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"/>
        </Style>
        <Style Selector="Button.menu-main-btn">
            <Setter Property="MinHeight" Value="51"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#111"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.menu-main-btn:pointerover">
            <Setter Property="BorderBrush" Value="#e6e6e6"/>
        </Style>
        <Style Selector="Button.menu-main-btn:pressed">
            <Setter Property="Padding" Value="16,10,12,8"/>
            <Setter Property="BorderBrush" Value="#0a0a0a"/>
        </Style>
        <Style Selector="Button.menu-main-btn.pulse, Button.header-button.pulse">
            <Style.Animations>
                <Animation Duration="0:0:0.8"
                           IterationCount="Infinite"
                           PlaybackDirection="Alternate">
                    <KeyFrame Cue="0%">
                        <Setter Property="BorderBrush" Value="#fff4a3"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="BorderBrush" Value="#facc15"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
            <Setter Property="BorderBrush" Value="#facc15"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="Button.menu-main-btn.pulse /template/ ContentPresenter#PART_ContentPresenter, Button.header-button.pulse /template/ ContentPresenter#PART_ContentPresenter">
            <Style.Animations>
                <Animation Duration="0:0:0.8"
                           IterationCount="Infinite"
                           PlaybackDirection="Alternate">
                    <KeyFrame Cue="0%">
                        <Setter Property="BorderBrush" Value="#fff7c2"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="BorderBrush" Value="#facc15"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
            <Setter Property="BorderBrush" Value="#facc15"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </Window.Styles>
    
    <DockPanel>
        <!-- Persistent Left Menu -->
        <Border Background="#2f2f2f"
                BorderBrush="#555"
                BorderThickness="0,0,1,0"
                Width="250"
                Padding="10,10,10,8"
                DockPanel.Dock="Left">
            <StackPanel Spacing="8">
                <Border Background="#3a3a3a"
                        BorderBrush="#555"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8"
                        Margin="0,0,0,4">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button Classes="menu-btn" Content="24h"
                                    Height="36"
                                    Padding="8,4"
                                    Background="{Binding IsRange24hActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#00ff00,#4a4a4a'}"
                                    Foreground="{Binding IsRange24hActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                                    Click="OnRange24hClicked"/>
                            <Button Classes="menu-btn" Content="2d"
                                    Height="36"
                                    Padding="8,4"
                                    Background="{Binding IsRange2dActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#00ff00,#4a4a4a'}"
                                    Foreground="{Binding IsRange2dActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                                    Click="OnRange2dClicked"/>
                            <Button Classes="menu-btn" Content="Week"
                                    Height="36"
                                    Padding="8,4"
                                    Background="{Binding IsRangeWeekActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#00ff00,#4a4a4a'}"
                                    Foreground="{Binding IsRangeWeekActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                                    Click="OnRangeWeekClicked"/>
                            <Button Classes="menu-btn" Content="Range"
                                    Height="36"
                                    Padding="8,4"
                                    Background="{Binding IsRangeCustomActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#00ff00,#4a4a4a'}"
                                    Foreground="{Binding IsRangeCustomActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                                    Click="OnPickRangeClicked"/>
                        </StackPanel>
                        <Grid ColumnDefinitions="95,6,*">
                            <ComboBox Grid.Column="0"
                                      Width="95"
                                      HorizontalAlignment="Left"
                                      ItemsSource="{Binding Profiles}"
                                      SelectedItem="{Binding ActiveProfile, Mode=TwoWay}"
                                      SelectionChanged="OnProfileSelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="local:ProcessingProfile">
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Grid.Column="2"
                                    Classes="menu-btn"
                                    Height="34"
                                    HorizontalAlignment="Stretch"
                                    Padding="8,4"
                                    Click="OnArchiveBrowseClicked"
                                    IsEnabled="{Binding IsArchiveBrowseEnabled}">
                                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                    <Path Width="18"
                                          Height="18"
                                          Stretch="Uniform"
                                          VerticalAlignment="Center"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Data="M2,4 L6,4 L7.2,5.4 L14,5.4 C14.7,5.4 15.2,5.9 15.2,6.6 L15.2,12.8 C15.2,13.5 14.7,14 14,14 L2.8,14 C2.1,14 1.6,13.5 1.6,12.8 L1.6,5.2 C1.6,4.5 2.1,4 2.8,4 Z M2.8,6.2 L2.8,12.8 L14,12.8 L14,6.6 L6.6,6.6 L5.4,5.2 L2.8,5.2 Z"/>
                                    <TextBlock Text="Archive" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Button Classes="menu-btn"
                                Content="Return to Live + Local"
                                Height="34"
                                HorizontalAlignment="Stretch"
                                Background="#ffaa00"
                                Foreground="#000000"
                                IsVisible="{Binding IsArchiveSessionActive}"
                                Click="OnReturnToLiveLocalClicked"/>
                        <TextBlock Text="{Binding ActiveArchiveText}"
                                   FontSize="11"
                                   Foreground="#ffd28a"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding IsArchiveSessionActive}"/>
                    </StackPanel>
                </Border>

                <Button Classes="menu-btn menu-main-btn"
                        Cursor="Hand"
                        HorizontalAlignment="Stretch"
                        Background="{Binding IsDashboardSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#33aaff,#4a4a4a'}"
                        Foreground="{Binding IsDashboardSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnDashboardClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Path Width="28" Height="28"
                              Stretch="Uniform"
                              VerticalAlignment="Center"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M7,2 C10.3,2 13,4.7 13,8 C13,9.5 12.5,10.9 11.5,12 L9.9,10.9 C10.6,10.1 11,9.1 11,8 C11,5.8 9.2,4 7,4 C4.8,4 3,5.8 3,8 C3,9.1 3.4,10.1 4.1,10.9 L2.5,12 C1.5,10.9 1,9.5 1,8 C1,4.7 3.7,2 7,2 Z M6.6,7.8 L9.6,5.8 L7.8,8.9 C7.5,9.5 6.6,9.4 6.3,8.8 C6.1,8.5 6.2,8.1 6.6,7.8 Z M2.8,7.4 L4.2,7.4 L4.2,8.6 L2.8,8.6 Z M6.4,3.7 L7.6,3.7 L7.6,5.1 L6.4,5.1 Z M9.8,7.4 L11.2,7.4 L11.2,8.6 L9.8,8.6 Z"/>
                        <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        <Border Background="#d62222"
                                CornerRadius="10"
                                MinWidth="20"
                                Height="20"
                                Padding="6,0"
                                IsVisible="{Binding UnreadAlertCount, Converter={StaticResource IntGreaterThanZeroConverter}}">
                            <TextBlock Text="{Binding UnreadAlertCount}"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="12"/>
                        </Border>
                    </StackPanel>
                </Button>

                <Separator Margin="0,2,0,2"/>

                <Button Classes="menu-btn menu-main-btn"
                        Classes.pulse="{Binding IsPolicePulseActive}"
                        Cursor="Hand"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding IsPoliceMenuVisible}"
                        Background="{Binding IsPoliceSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#2b74e4,#4a4a4a'}"
                        Foreground="{Binding IsPoliceSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnSectionPoliceClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Path Width="28" Height="28"
                              Stretch="Uniform"
                              VerticalAlignment="Center"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M7,1.4 L8.6,3.2 L11,3.6 L10.1,5.8 L11.1,8 L8.8,8.4 L7.2,10.2 L5.6,8.4 L3.3,8 L4.3,5.8 L3.4,3.6 L5.8,3.2 Z M7,4.3 L7.5,5.6 L8.9,5.7 L7.8,6.5 L8.1,7.9 L7,7.1 L5.9,7.9 L6.2,6.5 L5.1,5.7 L6.5,5.6 Z"/>
                        <TextBlock Text="Police" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="menu-btn menu-main-btn"
                        Classes.pulse="{Binding IsFirePulseActive}"
                        Cursor="Hand"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding IsFireMenuVisible}"
                        Background="{Binding IsFireSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#cf4b3c,#4a4a4a'}"
                        Foreground="{Binding IsFireSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#000000,#FFFFFF'}"
                        Click="OnSectionFireClicked">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Path Width="28" Height="28"
                              Stretch="Uniform"
                              VerticalAlignment="Center"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
