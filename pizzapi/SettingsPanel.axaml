<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:pizzapi"
             x:Class="pizzapi.SettingsPanel"
             x:Name="settingsPanel">
    <Border Padding="10">
        <DockPanel>
<TextBlock Text="Settings"
                        FontSize="20"
                        FontWeight="Bold"
                        DockPanel.Dock="Top"
                        Margin="0,0,0,10" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="10"
                        DockPanel.Dock="Bottom"
                        Margin="0,10,0,0">
                <Button x:Name="LoadButton" Content="Load" Width="90" />
                <Button x:Name="SaveButton" Content="Save" Width="90" />
                <Button x:Name="SaveAsButton" Content="Save As" Width="90" />
                <Button x:Name="CancelButton" Content="Close" Width="90" />
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Listen Port" FontSize="14" FontWeight="Bold" />
                        <TextBox x:Name="ListenPortTextBox" FontSize="14" />
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="Transcription Model" FontSize="14" FontWeight="Bold" />
                        <ComboBox x:Name="TranscriptionModelComboBox" Width="300" HorizontalAlignment="Left">
                            <ComboBoxItem Content="Default (engine default)" />
                            <ComboBoxItem Content="whisper-tiny (74MB)" />
                            <ComboBoxItem Content="whisper-base (142MB)" />
                            <ComboBoxItem Content="whisper-small (466MB)" />
                            <ComboBoxItem Content="whisper-medium (1.5GB)" />
                            <ComboBoxItem Content="whisper-large-v3 (2.9GB)" />
                            <ComboBoxItem Content="vosk-model-small-en-us-0.15 (50MB)" />
                            <ComboBoxItem Content="vosk-model-en-us-0.22 (1.8GB)" />
                            <ComboBoxItem Content="vosk-model-en-us-0.22-lgraph (128MB)" />
                        </ComboBox>
                        <TextBlock Text="Selecting a model will auto-download it if missing on first start."
                                   FontSize="11"
                                   Foreground="Gray"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="Transcription Engine" FontSize="14" FontWeight="Bold" />
                        <ComboBox x:Name="TranscriptionEngineComboBox" Width="200" HorizontalAlignment="Left">
                            <ComboBoxItem Content="Whisper" />
                            <ComboBoxItem Content="Vosk" />
                        </ComboBox>
                        <TextBlock Text="Engine must match the model family (whisper-* or vosk-*)."
                                   FontSize="11"
                                   Foreground="Gray"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="Email Provider" FontSize="14" FontWeight="Bold" />
                        <ComboBox x:Name="EmailProviderComboBox" Width="200" HorizontalAlignment="Left">
                            <ComboBoxItem Content="Gmail" />
                            <ComboBoxItem Content="Yahoo" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="Email address" FontSize="14" FontWeight="Bold" />
                        <TextBox x:Name="GmailUserTextBox" FontSize="14" />
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="App password (NOT account password):" FontSize="14" FontWeight="Bold" />
                        <TextBox x:Name="GmailPasswordTextBox" FontSize="14" />
                        <TextBlock Text="Use app password for selected provider."
                                   FontSize="11"
                                   Foreground="Gray"
                                   TextWrapping="Wrap" />
                        <Button x:Name="TestEmailButton"
                                Content="Test"
                                Width="90"
                                HorizontalAlignment="Left"
                                Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="Alert Audio" FontSize="14" FontWeight="Bold" />
                        <CheckBox x:Name="AutoplayAlertsCheckBox"
                                  Content="Enable autoplay audio for alert matches"
                                  FontSize="14" />
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
                            <TextBlock Text="Snooze duration:" VerticalAlignment="Center" />
                            <ComboBox x:Name="SnoozeDurationComboBox" Width="125">
                                <ComboBoxItem Content="5 minutes" />
                                <ComboBoxItem Content="15 minutes" />
                                <ComboBoxItem Content="30 minutes" />
                                <ComboBoxItem Content="1 hour" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="Talkgroups" FontSize="14" FontWeight="Bold" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="ImportTalkgroupsButton"
                                    Content="Import talkgroups..."
                                    Width="200"
                                    HorizontalAlignment="Left" />
                            <Button x:Name="ViewTalkgroupsButton"
                                    Content="View"
                                    Width="80"
                                    HorizontalAlignment="Left" />
                            <TextBlock x:Name="TalkgroupCountText"
                                       VerticalAlignment="Center"
                                       Foreground="#00ff00"
                                       Text="(0)" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="Logging" FontSize="14" FontWeight="Bold" />
                        <TextBlock Text="Trace level:" FontSize="14" Margin="0,5,0,0" />
                        <ComboBox x:Name="TraceLevelComboBox" Width="200" HorizontalAlignment="Left">
                            <ComboBoxItem Content="Error" />
                            <ComboBoxItem Content="Warning" />
                            <ComboBoxItem Content="Information" />
                            <ComboBoxItem Content="Verbose" />
                        </ComboBox>
                        <TextBlock FontSize="11"
                                   Foreground="Gray"
                                   Text="Verbose logging creates detailed logs but uses more disk space"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,0" />
                    </StackPanel>
                    
                    <StackPanel Spacing="5">
                        <TextBlock Text="Insights (LM Link)" FontSize="14" FontWeight="Bold" />
                        <CheckBox x:Name="LmLinkEnabledCheckBox"
                                  Content="Enable Insights via LM Link"
                                  FontSize="14" />
                        <CheckBox x:Name="DailyInsightsDigestCheckBox"
                                  Content="Get daily insights digest"
                                  FontSize="14" />
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
                            <TextBlock Text="Base URL:" VerticalAlignment="Center" Width="70" />
                            <TextBox x:Name="LmLinkBaseUrlTextBox" Width="360" FontSize="14" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
                            <TextBlock Text="Model:" VerticalAlignment="Center" Width="70" />
                            <TextBox x:Name="LmLinkModelTextBox" Width="200" FontSize="14" />
                            <TextBlock Text="API Key:" VerticalAlignment="Center" Width="60" />
                            <TextBox x:Name="LmLinkApiKeyTextBox" Width="180" FontSize="14" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
                            <TextBlock Text="Timeout (ms):" VerticalAlignment="Center" Width="90" />
                            <TextBox x:Name="LmLinkTimeoutTextBox" Width="80" FontSize="14" />
                            <TextBlock Text="Retries:" VerticalAlignment="Center" Width="50" />
                            <TextBox x:Name="LmLinkRetriesTextBox" Width="60" FontSize="14" />
                        </StackPanel>
                        <TextBlock Text="Base URL should point to LM Studio's LM Link (OpenAI-compatible) endpoint host."
                                   FontSize="11"
                                   Foreground="Gray"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="Settings File" FontSize="14" FontWeight="Bold" />
                        <TextBlock x:Name="SettingsPathText"
                                   FontSize="12"
                                   Foreground="#00ff00"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
